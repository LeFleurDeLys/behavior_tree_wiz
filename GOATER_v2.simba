//WriteLn wrapper with current time added, only logs a new msg if not similar to last one.
procedure log(s: string);
begin
  if (s = _LastDebugMsg) then Exit;
  _LastDebugMsg := s;
 WriteLn(GetTimeStamp('[hh:mm:ss:uu]') + ' ' + s);
end;


// -- BINARY CONDITION TREE | Left = False; Right = True | BECAUSE I CODE GOOFY STYLE(Standard is LeftyTruthy RightyFalsy)
procedure EvaluateNode(NodeName: String; Condition: Boolean; FalseBranch, TrueBranch: procedure);
begin
  log('Evaluated ' + NodeName + ': ' + BoolToStr(Condition));
  if Condition then
    TrueBranch()
  else
    FalseBranch();
end;

// -- Helper functions for finding pixels n shit without violating memory --
procedure checkAreaBounds(var Area: TBox);
begin
  Area.X1 := Min(Area.X1, Area.X2);
  Area.X2 := Max(Area.X1, Area.X2);
  Area.Y1 := Min(Area.Y1, Area.Y2);
  Area.Y2 := Max(Area.Y1, Area.Y2);
  if Area.X1 < 0 then Area.X1 := 0;
  if Area.Y1 < 0 then Area.Y1 := 0;
end;

function HasSquare(TPA: TPointArray; Size: Integer; var Corner: TPoint): Boolean;
var
  i, dx, dy: Integer;
  SortedTPA: TPointArray;
  IsSquare: Boolean;

  function HasPoint(const Pt: TPoint): Boolean;
  var
    L, R, M: Integer;
  begin
    L := 0;
    R := High(SortedTPA);
    while L <= R do
    begin
      M := L + (R - L) div 2;
      if (SortedTPA[M].Y < Pt.Y) then
        L := M + 1
      else if (SortedTPA[M].Y > Pt.Y) then
        R := M - 1
      else // Y matches, check X
      begin
        if (SortedTPA[M].X < Pt.X) then
          L := M + 1
        else if (SortedTPA[M].X > Pt.X) then
          R := M - 1
        else
          Exit(True);
      end;
    end;
    Result := False;
  end;

begin
  if Size <= 1 then
  begin
     if Length(TPA) > 0 then
     begin
       Corner := TPA[0];
       Exit(True);
     end;
     Exit(False);
  end;

  if Length(TPA) < Size * Size then Exit(False);

  // Copy and Sort TPA to allow binary search (O(N log N))
  // We use a copy to avoid modifying the passed TPA if it's reused elsewhere
  SortedTPA := Copy(TPA);
  SortedTPA.SortByX;
  SortedTPA.SortByY;

  for i := 0 to High(SortedTPA) do
  begin
    // Check if we have a square starting at SortedTPA[i] (Top-Left)

    // Optimization: Quickly check if the other 3 corners exist first
    if HasPoint(Point(SortedTPA[i].X + Size - 1, SortedTPA[i].Y)) and             // Top-Right
       HasPoint(Point(SortedTPA[i].X, SortedTPA[i].Y + Size - 1)) and             // Bottom-Left
       HasPoint(Point(SortedTPA[i].X + Size - 1, SortedTPA[i].Y + Size - 1)) then // Bottom-Right
    begin
      IsSquare := True;
      // Check the rest of the points
      for dy := 0 to Size - 1 do
      begin
        for dx := 0 to Size - 1 do
        begin
          // Skip corners we already checked
          if ((dx = 0) or (dx = Size - 1)) and ((dy = 0) or (dy = Size - 1)) then Continue;

          if not HasPoint(Point(SortedTPA[i].X + dx, SortedTPA[i].Y + dy)) then
          begin
            IsSquare := False;
            Break;
          end;
        end;
        if not IsSquare then Break;
      end;

      if IsSquare then
      begin
        Corner := SortedTPA[i];
        Exit(True);
      end;
    end;
  end;

  Result := False;
end;

// -- THIS SECTION CONTAINS OLDSCHOOL SIMBA METHODS I RECREATED FOR SIMBA 2000, BECAUSE I'M AN OLD FART STUCK IN MY WAYS -FiniLeNiaisage
function FindColoredArea(var x, y: Integer; Color: Integer; SearchBox: TBox; Tolerance: Integer; MinCount: Integer): Boolean;
var
  TPA: TPointArray;
  Corner: TPoint;
begin
  Result := False;
  checkAreaBounds(SearchBox);
  TPA := Target.FindColor(Color, Tolerance, SearchBox);
  if HasSquare(TPA, MinCount, Corner) then
  begin
    x := Corner.X;
    y := Corner.Y;
    Result := True;
  end;
end;


function FindColoredAreaTolerance(var x, y: Integer; Color: Integer; SearchBox: TBox; Tolerance: Integer; MinCount: Integer): Boolean;
var
  TPA: TPointArray;
  Corner: TPoint;
begin
  Result := False;
  checkAreaBounds(SearchBox);
  TPA := Target.FindColor(Color, Tolerance, SearchBox);
  if HasSquare(TPA, MinCount, Corner) then
  begin
    x := Corner.X;
    y := Corner.Y;
    Result := True;
  end;
end;

function FindColoredAreas(var ResultTPA: TPointArray; Color: Integer; SearchBox: TBox; Tolerance: Integer; MinCount: Integer): Boolean;
var
  Corner: TPoint;
begin
  Result := False;
  ResultTPA := Target.FindColor(Color, Tolerance, SearchBox);
  if HasSquare(ResultTPA, MinCount, Corner) then
    Result := True;
end;

function FindColoredAreasTolerance(var ResultTPA: TPointArray; Color: Integer; SearchBox: TBox; Tolerance: Integer; MinCount: Integer): Boolean;
var
  Corner: TPoint;
begin
  Result := False;
  ResultTPA := Target.FindColor(Color, Tolerance, SearchBox);
  if HasSquare(ResultTPA, MinCount, Corner) then
    Result := True;
end;

