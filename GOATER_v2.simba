function IsMining: Boolean;
var
  Bounds: TBoxArray;
  searchBounds: TBox;
  TPA: TPointArray;
  colorBounds: TBox;
  TextSearchArea: TBox;
begin
  // Define the initial search bounds for Mining plugin info panel
  searchBounds := Box(1, 1, 200, 420);

  // Find all pixels with color $00FF00 (Green font of MiningPlugin) within these bounds
  TPA := Target.FindColor($00FF00, 0, searchBounds);

  if Length(TPA) > 0 then
  begin
    // Calculate the bounding box containing all found pixels
    colorBounds := TPA.Bounds();

    // Create the search area from the color bounds
    TextSearchArea := colorBounds;

    // Search for "Mining" text inside the dynamic bounding box
    Bounds := LocateTextBounds(TextSearchArea, "Mining", [$00FF00], 0, RSFonts.PLAIN_12);

    // Return True if we found at least one match
    Result := (Length(Bounds) > 0);
  end
  else
  begin
    // No green pixels found, so we're not mining
    Result := False;
  end;
end;

