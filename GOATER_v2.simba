Function pointToBox(Point: TPoint; Size: Integer): TBox; overload;
begin
  Result := Box(Point.X-round(Size/2), Point.Y-round(Size/2), Point.X+round(Size/2), Point.Y+round(Size/2));
end;

function didClick(Red: Boolean; Time: integer): boolean;
var
  T : TStopwatch;
  B : TBox;
  colR, colG : TColorTolerance;
begin
  B := pointToBox(Mouse.Position, 30);
  checkAreaBounds(B);
  colR.Color := (255);
  colR.Tolerance := (15);
  colG.Color := (65535);
  colG.Tolerance := (15);
  T.start();
  while (T.Elapsed < Time) do
  begin
    Sleep(10);
    try
      if Red then
      begin
        begin
          if (Target.CountColor(colR.Color, colR.Tolerance, B) > 30) then
          begin
            log("Found the red from our click");
            Exit(true);
          end;
        end;
      end;
      except
      end;
    end;
end;

function didRedClick(TimeOut : Integer = 1000): Boolean;
begin
  Result := didClick(true, TimeOut);
end;

function didYellowClick(TimeOut : Integer = 1000): Boolean;
begin
  Result := didClick(false, TimeOut);
end;

procedure T2DPointArray.Shuffle(IndexesToShuffle : Integer);
var
  i: Integer;
begin
  //Will make it so we only shuffle the amount of indexs we want
  if self.Length > IndexesToShuffle then
  //Mixes the index around randomly
  for i := (IndexesToShuffle - 1) downto 0 do
    system.swap(self[i], self[random(i + 1)]);
end;

function TPointArray.Shuffle(): TPointArray;
var
  vIndex:int32;
begin
  for vIndex:=high(result:=self) downto 0 do
    system.swap(result[vIndex],result[random(vIndex+1)]);
  exit(result);
end;

