// --- HELPER FUNCTIONS ---
function FormatXP(XP: Int64): String;
var
  s: String;
  i, len: Integer;
begin
  s := IntToStr(XP);
  len := Length(s);
  Result := '';
  for i := 1 to len do
  begin
    Result := Result + s[i];
    if ((len - i) mod 3 = 0) and (i < len) then
      Result := Result + ',';
  end;
end;

function MsToTime(MS: Int64): string;
var
  h, m, s: Integer;
begin
  s := MS div 1000;
  h := s div 3600;
  m := (s mod 3600) div 60;
  s := s mod 60;

  Result := '';
  if h < 10 then Result := Result + '0';
  Result := Result + IntToStr(h) + ':';

  if m < 10 then Result := Result + '0';
  Result := Result + IntToStr(m) + ':';

  if s < 10 then Result := Result + '0';
  Result := Result + IntToStr(s);
end;

function LocateTextBounds(searchArea: TBox; searchText: String; colors: TColorArray; tolerance: Single; font: TPixelFont): TBoxArray;
var
  i: Integer;
  pt: TPoint;
  lines: TStringArray;
begin
  // Use RecognizeLines to populate OCR.Engine.Matches
  lines := OCR.RecognizeLines(searchArea, font, colors, tolerance);

  if OCR.Engine.Matches = [] then
  begin
    SetLength(Result, 0);
    Exit;
  end;

  // Filter matches to only include those containing our search text
  SetLength(Result, 0);
  pt := searchArea.TopLeft;

  for i := 0 to High(OCR.Engine.Matches) do
  begin
    if searchText in OCR.Engine.Matches[i].Text then
    begin
      SetLength(Result, Length(Result) + 1);
      Result[High(Result)] := OCR.Engine.Matches[i].Bounds.Offset(pt);
    end;
  end;
end;



