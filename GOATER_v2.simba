          if DidYellowClick then
            begin
              log('Yellow click detected, let''s run the tree again.');
              Exit;
            end;
        end else
          log('Did NOT find the Large guardian remains UpText we were looking for.');
    end else
      log('Did NOT find the Large guardian remains ColoredArea we were looking for.');
 end;

