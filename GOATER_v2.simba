// --- ASYNC GAME STATE ANALYZER ---

procedure GameStateAnalyzer_Init;
begin
end;

procedure LoginStateAnalyzer_Execute(Thread: TThread);
var
  LoggedIn: Boolean;
begin
  while not Thread.IsTerminated do
  begin
    try
      LoggedIn := RSClient.IsLoggedIn();

      GameStateLock.Enter;
      try
        GameState.FIsLoggedIn := LoggedIn;
      finally
        GameStateLock.Leave;
      end;
    except
      if not Thread.IsTerminated then
        //WriteLn('Error in LoginStateAnalyzer.');
    end;

    Sleep(1);
  end;
end;

procedure RunLoginStateAnalyzer;
begin
  LoginStateAnalyzer_Execute(CurrentThread());
end;

function SaveSettings(Settings: TGoaterSettings; FilePath: String): Boolean; forward;

procedure StatsThread_Execute(Thread: TThread);
var
  CurrentSessionTime: Int64;
  CurrentTotalXP, TotalGained, Mined, Magic, Craft, RCGain: Int64;
begin
  while not Thread.IsTerminated do
  begin
    CurrentSessionTime := GetTimeRunning();

    // Calculate stats
    CurrentTotalXP := GameState.GetXP();
    Mined := GameState.GetMiningXP();
    Magic := GameState.GetMagicXP();
    Craft := GameState.GetCraftingXP();

    StatsLock.Enter;
    try
      Settings.TotalRuntime := InitialRuntimeSnapshot + CurrentSessionTime;
      Settings.LastRuntime := CurrentSessionTime;

      if CurrentTotalXP > 0 then
      begin
        TotalGained := CurrentTotalXP - StartXP;
        if TotalGained < 0 then TotalGained := 0;

        // Update Totals (Initial Snapshot + Gain)
        Settings.TotalXP := InitialTotalXP + TotalGained;
        Settings.TotalMiningXP := InitialMiningXP + Mined;
        Settings.TotalMagicXP := InitialMagicXP + Magic;
        Settings.TotalCraftingXP := InitialCraftingXP + Craft;

        RCGain := TotalGained - Mined - Magic - Craft;
        if RCGain < 0 then RCGain := 0;
        Settings.TotalRunecraftingXP := InitialRunecraftingXP + RCGain;

        // Update Lasts (Current Session Gain)
        Settings.LastTotalXP := TotalGained;
        Settings.LastMiningXP := Mined;
        Settings.LastMagicXP := Magic;
        Settings.LastCraftingXP := Craft;
        Settings.LastRunecraftingXP := RCGain;
      end;

      SaveSettings(Settings, SETTINGS_PATH);
    finally
      StatsLock.Leave;
    end;
    Sleep(1000);
  end;
end;

procedure RunStatsThread;
begin
  StatsThread_Execute(CurrentThread());
end;

function SaveSettings(Settings: TGoaterSettings; FilePath: String): Boolean;
var
  FileContent: String;
begin
  try
    FileContent := '';
    FileContent += 'craft_air=' + BoolToStr(Settings.CraftAir) + #13#10;
    FileContent += 'craft_mind=' + BoolToStr(Settings.CraftMind) + #13#10;
    FileContent += 'craft_water=' + BoolToStr(Settings.CraftWater) + #13#10;
    FileContent += 'craft_earth=' + BoolToStr(Settings.CraftEarth) + #13#10;
    FileContent += 'craft_fire=' + BoolToStr(Settings.CraftFire) + #13#10;
    FileContent += 'craft_body=' + BoolToStr(Settings.CraftBody) + #13#10;
    FileContent += 'craft_cosmic=' + BoolToStr(Settings.CraftCosmic) + #13#10;
    FileContent += 'craft_chaos=' + BoolToStr(Settings.CraftChaos) + #13#10;
    FileContent += 'craft_nature=' + BoolToStr(Settings.CraftNature) + #13#10;
    FileContent += 'craft_law=' + BoolToStr(Settings.CraftLaw) + #13#10;
    FileContent += 'craft_death=' + BoolToStr(Settings.CraftDeath) + #13#10;
    FileContent += 'craft_blood=' + BoolToStr(Settings.CraftBlood) + #13#10;
    FileContent += 'use_small_pouch=' + BoolToStr(Settings.UseSmall) + #13#10;
    FileContent += 'use_medium_pouch=' + BoolToStr(Settings.UseMedium) + #13#10;
    FileContent += 'use_large_pouch=' + BoolToStr(Settings.UseLarge) + #13#10;
    FileContent += 'use_giant_pouch=' + BoolToStr(Settings.UseGiant) + #13#10;
    FileContent += 'use_colossal_pouch=' + BoolToStr(Settings.UseColossal) + #13#10;
    FileContent += 'use_binding_necklace=' + BoolToStr(Settings.UseBindingNecklace) + #13#10;
    FileContent += 'use_highest_lvl_rune=' + BoolToStr(Settings.UseHighestLvlRune) + #13#10;
    FileContent += 'use_highest_points=' + BoolToStr(Settings.UseHighestPoints) + #13#10;
    FileContent += 'total_runtime=' + IntToStr(Settings.TotalRuntime) + #13#10;
    FileContent += 'total_xp=' + IntToStr(Settings.TotalXP) + #13#10;
    FileContent += 'total_rc_xp=' + IntToStr(Settings.TotalRunecraftingXP) + #13#10;
    FileContent += 'total_magic_xp=' + IntToStr(Settings.TotalMagicXP) + #13#10;
    FileContent += 'total_mining_xp=' + IntToStr(Settings.TotalMiningXP) + #13#10;
    FileContent += 'total_crafting_xp=' + IntToStr(Settings.TotalCraftingXP) + #13#10;
    FileContent += 'last_runtime=' + IntToStr(Settings.LastRuntime) + #13#10;
    FileContent += 'last_total_xp=' + IntToStr(Settings.LastTotalXP) + #13#10;
    FileContent += 'last_rc_xp=' + IntToStr(Settings.LastRunecraftingXP) + #13#10;
    FileContent += 'last_magic_xp=' + IntToStr(Settings.LastMagicXP) + #13#10;
    FileContent += 'last_mining_xp=' + IntToStr(Settings.LastMiningXP) + #13#10;
    FileContent += 'last_crafting_xp=' + IntToStr(Settings.LastCraftingXP) + #13#10;

    Result := FileWrite(FilePath, FileContent);
  except
    log('Error saving settings to ' + FilePath);
    Result := False;
  end;
end;

function LoadSettings(var Settings: TGoaterSettings; FilePath: String): Boolean;
var
  FileContent: String;
  Lines: TStringArray;
  i, p: Integer;
  Key, Value: String;
begin
  if not FileExists(FilePath) then
    Exit(False);

  try
    FileContent := FileRead(FilePath);
    Lines := FileContent.Split(#13#10, True);

    for i := 0 to High(Lines) do
    begin
      p := Pos('=', Lines[i]);
      if p > 0 then
      begin
        Key := Trim(Copy(Lines[i], 1, p - 1));
        Value := Trim(Copy(Lines[i], p + 1, Length(Lines[i])));

        try
          case Lowercase(Key) of
            'craft_air': Settings.CraftAir := StrToBool(Value);
            'craft_mind': Settings.CraftMind := StrToBool(Value);
            'craft_water': Settings.CraftWater := StrToBool(Value);
            'craft_earth': Settings.CraftEarth := StrToBool(Value);
            'craft_fire': Settings.CraftFire := StrToBool(Value);
            'craft_body': Settings.CraftBody := StrToBool(Value);
            'craft_cosmic': Settings.CraftCosmic := StrToBool(Value);
            'craft_chaos': Settings.CraftChaos := StrToBool(Value);
            'craft_nature': Settings.CraftNature := StrToBool(Value);
            'craft_law': Settings.CraftLaw := StrToBool(Value);
            'craft_death': Settings.CraftDeath := StrToBool(Value);
            'craft_blood': Settings.CraftBlood := StrToBool(Value);
            'use_small_pouch': Settings.UseSmall := StrToBool(Value);
            'use_medium_pouch': Settings.UseMedium := StrToBool(Value);
            'use_large_pouch': Settings.UseLarge := StrToBool(Value);
            'use_giant_pouch': Settings.UseGiant := StrToBool(Value);
            'use_colossal_pouch': Settings.UseColossal := StrToBool(Value);
            'use_binding_necklace': Settings.UseBindingNecklace := StrToBool(Value);
            'use_highest_lvl_rune': Settings.UseHighestLvlRune := StrToBool(Value);
            'use_highest_points': Settings.UseHighestPoints := StrToBool(Value);
            'total_runtime': Settings.TotalRuntime := StrToInt(Value, 0);
            'total_xp': Settings.TotalXP := StrToInt(Value, 0);
            'total_rc_xp': Settings.TotalRunecraftingXP := StrToInt(Value, 0);
            'total_magic_xp': Settings.TotalMagicXP := StrToInt(Value, 0);
            'total_mining_xp': Settings.TotalMiningXP := StrToInt(Value, 0);
            'total_crafting_xp': Settings.TotalCraftingXP := StrToInt(Value, 0);
            'last_runtime': Settings.LastRuntime := StrToInt(Value, 0);
            'last_total_xp': Settings.LastTotalXP := StrToInt(Value, 0);
            'last_rc_xp': Settings.LastRunecraftingXP := StrToInt(Value, 0);
            'last_magic_xp': Settings.LastMagicXP := StrToInt(Value, 0);
            'last_mining_xp': Settings.LastMiningXP := StrToInt(Value, 0);
            'last_crafting_xp': Settings.LastCraftingXP := StrToInt(Value, 0);
          end;
        except
          log('Warning: Invalid boolean value for key "' + Key + '": "' + Value + '". Using default.');
        end;
      end;
    end;
    Result := True;
  except
    log('Error reading or parsing settings file: ' + FilePath);
    Result := False;
  end;
end;

procedure XPAnalyzer_Execute(Thread: TThread);
var
  MiningSearchBox: TBox;
  MiningTPA: TPointArray;
  MiningLines: TStringArray;
  i: Integer;
  CurrentXP, PreviousXP, XPDelta: Integer;
  IsMiningNow: Boolean;
  RawXP, CleanXP: string;

begin
  PreviousXP := -1;
  try
    while not Thread.IsTerminated do
    begin
      try
        CurrentXP := -1;
        try

          if XPBar.Size <> ERSXPBarSize.UNKNOWN then
          begin
            begin
              RawXP := GameStateAnalyzer.FXPOCR.Recognize(XPBar.Bounds, XPBar.Font, [$FFFFFF], 0);
              CleanXP := '';
              for i := 1 to Length(RawXP) do
              begin
                if (RawXP[i] in '0123456789') then
                  CleanXP := CleanXP + RawXP[i];
              end;
              CurrentXP := StrToInt(CleanXP, -1);
            end;
          end;
        except
        end;

        if (PreviousXP > -1) and (CurrentXP > PreviousXP) then
        begin
          XPDelta := CurrentXP - PreviousXP;

          IsMiningNow := False;
          MiningSearchBox := Box(1, 1, 200, 420);
          MiningTPA := Target.FindColor($00FF00, 0, MiningSearchBox);

          if Length(MiningTPA) > 0 then
          begin
            MiningLines := GameStateAnalyzer.FXPOCR.RecognizeLines(MiningTPA.Bounds(), RSFonts.PLAIN_12, [$00FF00], 0);
            for i := 0 to High(MiningLines) do
            begin
              if Pos('Mining', MiningLines[i]) > 0 then
              begin
                IsMiningNow := True;
                Break;
              end;
            end;
          end;

          if IsMiningNow then
        begin
          GameStateLock.Enter;
          try
            GameState.FMiningXP := GameState.FMiningXP + XPDelta;
          finally
            GameStateLock.Leave;
          end;
        end else
        begin
          // Crafting XP Detection
          if (XPDelta < 4000) then
          begin
            // We use GetTile safely here as it handles its own lock
            if (GameState.GetTile().X >= 3610) and (GameState.GetTile().X <= 3613) and
               (GameState.GetTile().Y >= 9485) and (GameState.GetTile().Y <= 9488) then
            begin
              GameStateLock.Enter;
              try
                GameState.FCraftingXP := GameState.FCraftingXP + XPDelta;
              finally
                GameStateLock.Leave;
              end;
            end;
          end;
        end;
      end;

      if CurrentXP > -1 then
      begin
        PreviousXP := CurrentXP;

        GameStateLock.Enter;
        try
           GameState.FXP := CurrentXP;
        finally
           GameStateLock.Leave;
        end;
      end;

      except
        if not Thread.IsTerminated then
          //WriteLn('Error in XPAnalyzer.');
      end;

      Sleep(1);
    end;
  finally

  end;
end;

procedure PositionAnalyzer_Execute(Thread: TThread);
var
  NewChunk, NewRegion, TileID: String;
  NewTile: TPoint;
  OverlaySearchBox, OverlayBounds: TBox;
  TPA: TPointArray;
  Lines: TStringArray;
  i, j: Integer;
  LineText, CleanText: String;
begin
  while not Thread.IsTerminated do
  begin
    try
      // 1. Find the overlay (dark background)
      OverlaySearchBox := Box(1, 1, 200, 420);
      TPA := Target.FindColor($2D3438, 10, OverlaySearchBox);

      if Length(TPA) > 0 then
        OverlayBounds := TPA.Bounds()
      else
        OverlayBounds := Box(0, 0, 0, 0);

      NewChunk := '';
      NewRegion := '';
      TileID := '';

      // 2. Perform OCR operations OUTSIDE the critical section
      if (OverlayBounds.X2 > 0) then
      begin
        // Single OCR pass to get all text in the overlay
        Lines := GameStateAnalyzer.FPositionOCR.RecognizeLines(OverlayBounds, RSFonts.PLAIN_12, [$FFFFFF], 0);

        for i := 0 to High(Lines) do
        begin
          LineText := Lines[i];

          // Basic check for labels
          if (Pos('Chunk', LineText) > 0) or (Pos('Region', LineText) > 0) or (Pos('Tile', LineText) > 0) then
          begin
             CleanText := '';
             for j := 1 to Length(LineText) do
             begin
               if (LineText[j] in '0123456789') then
                 CleanText := CleanText + LineText[j];
             end;

             if (Pos('Chunk', LineText) > 0) then NewChunk := CleanText;
             if (Pos('Region', LineText) > 0) then NewRegion := CleanText;
             if (Pos('Tile', LineText) > 0) then TileID := CleanText;
          end;
        end;
      end;

      NewTile := Point(-1, -1);
      if Length(TileID) >= 8 then
      begin
        try
          NewTile.X := StrToInt(Copy(TileID, 1, 4));
          NewTile.Y := StrToInt(Copy(TileID, 5, 4));
        except
          NewTile := Point(-1, -1);
        end;
      end;

      // 3. Critical Section: Only update the shared state
      GameStateLock.Enter;
      try
        GameState.FChunk := NewChunk;
        GameState.FRegion := NewRegion;
        GameState.FTile := NewTile;
        GameState.FLastUpdate := GetTimeRunning();
      finally
        GameStateLock.Leave;
      end;

    except
      if not Thread.IsTerminated then
        //WriteLn('Error in PositionAnalyzer.');
    end;

    Sleep(1);
  end;
end;

procedure RunPositionAnalyzer;
begin
    PositionAnalyzer_Execute(CurrentThread());
end;

procedure RunXPAnalyzer;
begin
    XPAnalyzer_Execute(CurrentThread());
end;

procedure GameStateAnalyzer_Start;
begin
  if GameStateAnalyzer.FPositionThread = nil then
    GameStateAnalyzer.FPositionThread := TThread.Create(@RunPositionAnalyzer);
  if GameStateAnalyzer.FXPThread = nil then
    GameStateAnalyzer.FXPThread := TThread.Create(@RunXPAnalyzer);
  if GameStateAnalyzer.FLoginThread = nil then
    GameStateAnalyzer.FLoginThread := TThread.Create(@RunLoginStateAnalyzer);
end;

procedure GameStateAnalyzer_Terminate;
begin
  if GameStateAnalyzer.FPositionThread <> nil then GameStateAnalyzer.FPositionThread.Terminate;
  if GameStateAnalyzer.FXPThread <> nil then GameStateAnalyzer.FXPThread.Terminate;
  if GameStateAnalyzer.FLoginThread <> nil then GameStateAnalyzer.FLoginThread.Terminate;
end;

procedure GameStateAnalyzer_WaitFor;
begin
  if GameStateAnalyzer.FPositionThread <> nil then GameStateAnalyzer.FPositionThread.WaitForTerminate;
  if GameStateAnalyzer.FXPThread <> nil then GameStateAnalyzer.FXPThread.WaitForTerminate;
  if GameStateAnalyzer.FLoginThread <> nil then GameStateAnalyzer.FLoginThread.WaitForTerminate;
end;

procedure GameStateAnalyzer_Free;
begin
  if (GameStateAnalyzer.FPositionThread <> nil) then
  begin
    GameStateAnalyzer.FPositionThread.Terminate;
    GameStateAnalyzer.FPositionThread.WaitForTerminate;
    GameStateAnalyzer.FPositionThread.Free;
    GameStateAnalyzer.FPositionThread := nil;
  end;
  if (GameStateAnalyzer.FXPThread <> nil) then
  begin
    GameStateAnalyzer.FXPThread.Terminate;
    GameStateAnalyzer.FXPThread.WaitForTerminate;
    GameStateAnalyzer.FXPThread.Free;
    GameStateAnalyzer.FXPThread := nil;
  end;
  if (GameStateAnalyzer.FLoginThread <> nil) then
  begin
    GameStateAnalyzer.FLoginThread.Terminate;
    GameStateAnalyzer.FLoginThread.WaitForTerminate;
    GameStateAnalyzer.FLoginThread.Free;
    GameStateAnalyzer.FLoginThread := nil;
  end;
end;

