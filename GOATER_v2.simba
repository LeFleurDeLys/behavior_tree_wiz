(* AnthroMove*)
procedure AnthroMove(Point: TPoint);
var
  mPt: TPoint;
  S: Int32;
  Miss: Double;
  Range: Int64;
begin
  S := MouseDefaultSpeed;
  Range := Trunc(Power(Mouse.Position.DistanceTo(Point), 0.73)); // how much possible range to miss
  Miss := RandomMode(0.9, 0.1, 1.5); // Where miss will happen. 1 = destination (P).
  mPt.X := Trunc((1-Miss)*Mouse.Position.X + Miss*Point.X);
  mPt.Y := Trunc((1-Miss)*Mouse.Position.Y + Miss*Point.Y);
  mPt.X += Round(GaussRand(0, Range / 2));
  mPt.Y += Round(GaussRand(0, Range / 2));
  Mouse.Move(mPt);
  Mouse.Speed := S * 0.85;
  Mouse.Move(Point);
  Mouse.Speed := S;
end;

(*MMouseOffClient*)
procedure MMouseOffClient(Direction: String);
var
  B: TBoxArray;
  P: TPoint;
  i, W, H: Integer;
begin
  W := Target.Width;
  H := Target.Height;
  SetLength(B, 4);
  B[0] := Box(-444, -444, W, 0); //top
  B[1] := Box(0, H, W, H +3); //bottom
  B[2] := Box(0-444, 0, 0, H); //left
  B[3] := Box(W, 0, W +444, H); //right
  case Lowercase(Direction) of
    'top': i := 0;
    'bottom':  i := 1;
    'left': i := 2;
    'right': i := 3;
    'rand', 'random': i := Random(4);
    else
      log('Wrong direction');
  end;
  P := Point(Random(B[i].X1, B[i].X2), Random(B[i].Y1, B[i].Y2));
  AnthroMove(P);
end;

(*pickUpMouse*)
procedure pickUpMouse();
var
  cx,cy,XX,YY : Integer;
begin
  cx := Mouse.Position.X;
  cy := Mouse.Position.Y;
  XX := cx;
  YY := cy;
  if(Random(2) = 0)then
    AnthroMove(point(cx-2-Random(9), cy-8-Random(21)))
  else
    AnthroMove(point(cx+3, cy-8-Random(19)));
  sleep(1337 + Random(-137,666));
  if(Random(2) = 0)then
    Mouse.Move(Mouse.Miss(Point(XX+random(1,9),YY+random(2,14))))
  else
    Mouse.Move(Mouse.Miss(Point(XX-3-Random(1,9),YY+random(3, 18))));
end;

function RandomDirection: String;
begin
if not CheckDone then       //Var to make sure we don't resset every loop
  case Random(0,3) of  //We assign a side we are most likely to mouse off to for this session
  0 : MostLikely := 'top';
  1 : MostLikely := 'bottom';
  2 : MostLikely := 'left';
  3 : MostLikely := 'right';
  end
 else
  CheckDone:= True;
  result := MostLikely;
end;

