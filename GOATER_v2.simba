    TotalXP: Int64;
    TotalRunecraftingXP: Int64;
    TotalMagicXP: Int64;
    TotalMiningXP: Int64;
    TotalCraftingXP: Int64;
    LastRuntime: Int64;
    LastTotalXP: Integer;
    LastRunecraftingXP: Integer;
    LastMagicXP: Integer;
    LastMiningXP: Integer;
    LastCraftingXP: Integer;
  end;

