    CraftAir, CraftMind, CraftWater, CraftEarth, CraftFire, CraftBody,
    CraftCosmic, CraftChaos, CraftNature, CraftLaw, CraftDeath, CraftBlood: Boolean;
    UseSmall, UseMedium, UseLarge, UseGiant, UseColossal: Boolean;
    UseBindingNecklace, UseHighestLvlRune, UseHighestPoints: Boolean;
