procedure StartMining;
var
RemainsPnt : TPoint;
begin
  log('Action: StartMining');

    if FindColoredAreas(TPAS, RemainsLargeCol, MainScreen.Bounds, 0, 2) then
    begin
      TPAS.Shuffle;
      RemainsPnt := TPAS[0];   //Simply choose a random TPoint from the ones we gathered
