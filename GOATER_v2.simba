  PortalPanelPluginBox := Box(250, 50, (Target.Width div 2), 100);

  // Finds the smaller overlay (dark border of plugin's info panel) for quicker OCR on main thread (need to keep TThread count <= 7)
  TPA := Target.FindColor($2D3438, 10, PortalPanelPluginBox);

  if Length(TPA) > 0 then
    PortalPanelPluginBox := TPA.Bounds();

  // Search for "Time to start" text inside the dynamic bounding box and gathere the bounds of its line (so we can search for time counting down)
  Bounds := LocateTextBounds(PortalPanelPluginBox, 'Time to start', [$FFFFFF], 0, RSFonts.PLAIN_12);


  Result :=False; //Placeholder while we code
