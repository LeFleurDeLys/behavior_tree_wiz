// Root Nodes
procedure IsGameStartedNode;
begin
  if (XPBar.Size = ERSXPBarSize.UNKNOWN) and (XPBar.SetupAttempts < 3) then
    XPBar.Setup();

  Condition := IsGameStarted();
  EvaluateNode('IsGameStartedNode', Condition, @IsInBankAreaBeforeGameNode, @IsInBankAreaNode);
end;

procedure ROOT_IsLoggedInNode;
begin
  Condition := GameState.IsLoggedIn();
  EvaluateNode('ROOT_IsLoggedInNode', Condition, @HandleLoginAndBreaks, @IsGameStartedNode);
end;

// -- GUI SECTION --
var
  // UI Components
  cbAirRune, cbMindRune, cbWaterRune, cbEarthRune, cbFireRune, cbBodyRune,
    cbCosmicRune, cbChaosRune, cbNatureRune, cbLawRune, cbDeathRune, cbBloodRune: TLazCheckBox;
  cbSmallPouch, cbMediumPouch, cbLargePouch, cbGiantPouch, cbColossalPouch: TLazCheckBox;
  cbBindingNecklace, cbHighestLvlRune, cbHighestPoints: TLazCheckBox;

type
  TUIHandler = record
    _Dummy: Integer;
  end;

var
  UIHandler: TUIHandler;

procedure TUIHandler.OnMethodCheck(Sender: TLazObject);
begin
  if TLazCheckBox(Sender).isChecked then
  begin
    if Sender <> cbBindingNecklace then cbBindingNecklace.setChecked(False);
    if Sender <> cbHighestLvlRune then cbHighestLvlRune.setChecked(False);
    if Sender <> cbHighestPoints then cbHighestPoints.setChecked(False);
  end;
end;

procedure TScriptForm.OnStart(sender: TLazObject); override;
begin

  // --- SETTINGS LOGIC (Stays Here) ---
  // Runes
  Settings.CraftAir := cbAirRune.isChecked();
  Settings.CraftMind := cbMindRune.isChecked();
  Settings.CraftWater := cbWaterRune.isChecked();
  Settings.CraftEarth := cbEarthRune.isChecked();
  Settings.CraftFire := cbFireRune.isChecked();
  Settings.CraftBody := cbBodyRune.isChecked();
  Settings.CraftCosmic := cbCosmicRune.isChecked();
  Settings.CraftChaos := cbChaosRune.isChecked();
  Settings.CraftNature := cbNatureRune.isChecked();
  Settings.CraftLaw := cbLawRune.isChecked();
  Settings.CraftDeath := cbDeathRune.isChecked();
  Settings.CraftBlood := cbBloodRune.isChecked();

  // Pouches
  Settings.UseSmall := cbSmallPouch.isChecked();
  Settings.UseMedium := cbMediumPouch.isChecked();
  Settings.UseLarge := cbLargePouch.isChecked();
  Settings.UseGiant := cbGiantPouch.isChecked();
  Settings.UseColossal := cbColossalPouch.isChecked();

  // Runecrafting Method
  Settings.UseBindingNecklace := cbBindingNecklace.isChecked();
  Settings.UseHighestLvlRune := cbHighestLvlRune.isChecked();
  Settings.UseHighestPoints := cbHighestPoints.isChecked();

  // Initialize runtime snapshot
  InitialRuntimeSnapshot := Settings.TotalRuntime;
  InitialTotalXP := Settings.TotalXP;
  InitialRunecraftingXP := Settings.TotalRunecraftingXP;
  InitialMagicXP := Settings.TotalMagicXP;
  InitialMiningXP := Settings.TotalMiningXP;
  InitialCraftingXP := Settings.TotalCraftingXP;

  // --- SAVE CONFIG (Stays Here) ---
  if not SaveSettings(Settings, SETTINGS_PATH) then
    log('Failed to save settings to ' + SETTINGS_PATH);


  // Signal the main script block to start execution and close the GUI

  Self.Form.OnClose := nil;
  Self.Form.Close;
end;


procedure SetDefaultSettings;
begin
  // This procedure sets all settings to a default value
  Settings.CraftAir := False; Settings.CraftMind := False; Settings.CraftWater := False;
  Settings.CraftEarth := False; Settings.CraftFire := False; Settings.CraftBody := False;
  Settings.CraftCosmic := False; Settings.CraftChaos := False; Settings.CraftNature := False;
  Settings.CraftLaw := False; Settings.CraftDeath := False; Settings.CraftBlood := False;
  Settings.UseSmall := False; Settings.UseMedium := False; Settings.UseLarge := False;
  Settings.UseGiant := False; Settings.UseColossal := False;
  Settings.UseBindingNecklace := False; Settings.UseHighestLvlRune := False; Settings.UseHighestPoints := True;
  Settings.TotalRuntime := 0;
  Settings.TotalXP := 0;
  Settings.TotalRunecraftingXP := 0;
  Settings.TotalMagicXP := 0;
  Settings.TotalMiningXP := 0;
  Settings.TotalCraftingXP := 0;
  Settings.LastRuntime := 0;
  Settings.LastTotalXP := 0;
  Settings.LastRunecraftingXP := 0;
  Settings.LastMagicXP := 0;
  Settings.LastMiningXP := 0;
  Settings.LastCraftingXP := 0;
end;

procedure TScriptForm.Init;
var
  tab: TLazTabSheet;
  runePanel, pouchPanel, methodPanel, statsPanel: TLazPanel;
  lbl: TLazLabel;

  procedure InitCheck(var CB: TLazCheckBox; Panel: TLazPanel; Name, Key: String; Top: Integer; DefaultValue: Boolean);
  begin
    CB := TLazCheckBox.CreateEx(Panel, Name);
    CB.Left := 10;
    CB.Top := Top;
    CB.setChecked(DefaultValue);
  end;

begin
  // Initialize settings to default values first
  SetDefaultSettings;
  // Attempt to load settings from file, overwriting defaults if successful
  if not LoadSettings(Settings, SETTINGS_PATH) then
  begin
    log('Settings file not found or failed to load. Using default values.');
    // Optionally, you could create a default settings file here
    // SaveSettings(Settings, SETTINGS_PATH);
  end;
  tab := Self.CreateTab('Script Settings');

  // Rune Panel (Left)
  runePanel := TLazPanel.CreateEx(tab);
  runePanel.Left := 5;
  runePanel.Top := 5;
  runePanel.Width := 180;
  runePanel.Height := 340;
  runePanel.Caption := '';

  lbl := TLazLabel.CreateEx(runePanel);
  lbl.Caption := 'Runes to Craft';
  lbl.Left := 10;
  lbl.Top := 5;
  lbl.Font.Name := 'Arial Black';
  lbl.Font.Size := 11;


  InitCheck(cbAirRune, runePanel, 'Air Rune', 'craft_air', 35, Settings.CraftAir);
  InitCheck(cbMindRune, runePanel, 'Mind Rune', 'craft_mind', 60, Settings.CraftMind);
  InitCheck(cbWaterRune, runePanel, 'Water Rune', 'craft_water', 85, Settings.CraftWater);
  InitCheck(cbEarthRune, runePanel, 'Earth Rune', 'craft_earth', 110, Settings.CraftEarth);
  InitCheck(cbFireRune, runePanel, 'Fire Rune', 'craft_fire', 135, Settings.CraftFire);
  InitCheck(cbBodyRune, runePanel, 'Body Rune', 'craft_body', 160, Settings.CraftBody);
  InitCheck(cbCosmicRune, runePanel, 'Cosmic Rune', 'craft_cosmic', 185, Settings.CraftCosmic);
  InitCheck(cbChaosRune, runePanel, 'Chaos Rune', 'craft_chaos', 210, Settings.CraftChaos);
  InitCheck(cbNatureRune, runePanel, 'Nature Rune', 'craft_nature', 235, Settings.CraftNature);
  InitCheck(cbLawRune, runePanel, 'Law Rune', 'craft_law', 260, Settings.CraftLaw);
  InitCheck(cbDeathRune, runePanel, 'Death Rune', 'craft_death', 285, Settings.CraftDeath);
  InitCheck(cbBloodRune, runePanel, 'Blood Rune', 'craft_blood', 310, Settings.CraftBlood);

  // Pouch Panel (Right)
  pouchPanel := TLazPanel.CreateEx(tab);
  pouchPanel.Left := 200;
  pouchPanel.Top := 5;
  pouchPanel.Width := 180;
  pouchPanel.Height := 340;
  pouchPanel.Caption := '';

  lbl := TLazLabel.CreateEx(pouchPanel);
  lbl.Caption := 'Pouches to Use';
  lbl.Left := 10;
  lbl.Top := 5;
  lbl.Font.Name := 'Arial Black';
  lbl.Font.Size := 11;


  InitCheck(cbSmallPouch, pouchPanel, 'Small Pouch', 'use_small_pouch', 35, Settings.UseSmall);
  InitCheck(cbMediumPouch, pouchPanel, 'Medium Pouch', 'use_medium_pouch', 60, Settings.UseMedium);
  InitCheck(cbLargePouch, pouchPanel, 'Large Pouch', 'use_large_pouch', 85, Settings.UseLarge);
  InitCheck(cbGiantPouch, pouchPanel, 'Giant Pouch', 'use_giant_pouch', 110, Settings.UseGiant);
  InitCheck(cbColossalPouch, pouchPanel, 'Colossal Pouch', 'use_colossal_pouch', 135, Settings.UseColossal);

  // Runecrafting Method Panel (Middle)
  methodPanel := TLazPanel.CreateEx(tab);
  methodPanel.Left := 395;
  methodPanel.Top := 5;
  methodPanel.Width := 180;
  methodPanel.Height := 340;
  methodPanel.Caption := '';

  lbl := TLazLabel.CreateEx(methodPanel);
  lbl.Caption := 'RCing method';
  lbl.Left := 10;
  lbl.Top := 5;
  lbl.Font.Name := 'Arial Black';
  lbl.Font.Size := 11;


  cbBindingNecklace := TLazCheckBox.CreateEx(methodPanel, 'Binding necklace');
  cbBindingNecklace.Left := 10;
  cbBindingNecklace.Top := 35;
  cbBindingNecklace.setChecked(Settings.UseBindingNecklace);
  cbBindingNecklace.OnChange := @UIHandler.OnMethodCheck;

  cbHighestLvlRune := TLazCheckBox.CreateEx(methodPanel, 'Highest lvl rune');
  cbHighestLvlRune.Left := 10;
  cbHighestLvlRune.Top := 60;
  cbHighestLvlRune.setChecked(Settings.UseHighestLvlRune);
  cbHighestLvlRune.OnChange := @UIHandler.OnMethodCheck;

  cbHighestPoints := TLazCheckBox.CreateEx(methodPanel, 'Highest amount of points');
  cbHighestPoints.Left := 10;
  cbHighestPoints.Top := 85;
  cbHighestPoints.setChecked(Settings.UseHighestPoints);
  cbHighestPoints.OnChange := @UIHandler.OnMethodCheck;

  // Statistics Panel (Rightmost)
  statsPanel := TLazPanel.CreateEx(tab);
  statsPanel.Left := 590;
  statsPanel.Top := 5;
  statsPanel.Width := 180;
  statsPanel.Height := 340;
  statsPanel.Caption := '';

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Statistics';
  lbl.Left := 10;
  lbl.Top := 5;
  lbl.Font.Name := 'Arial Black';
  lbl.Font.Size := 11;


  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Total Runtime: ' + MsToTime(Settings.TotalRuntime);
  lbl.Left := 10;
  lbl.Top := 35;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Total XP: ' + FormatXP(Settings.TotalXP);
  lbl.Left := 10;
  lbl.Top := 60;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Total RC XP: ' + FormatXP(Settings.TotalRunecraftingXP);
  lbl.Left := 10;
  lbl.Top := 85;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Total Magic XP: ' + FormatXP(Settings.TotalMagicXP);
  lbl.Left := 10;
  lbl.Top := 110;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Total Mining XP: ' + FormatXP(Settings.TotalMiningXP);
  lbl.Left := 10;
  lbl.Top := 135;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Total Crafting XP: ' + FormatXP(Settings.TotalCraftingXP);
  lbl.Left := 10;
  lbl.Top := 160;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;


  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Last Runtime: ' + MsToTime(Settings.LastRuntime);
  lbl.Left := 10;
  lbl.Top := 185;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Last Total XP: ' + FormatXP(Settings.LastTotalXP);
  lbl.Left := 10;
  lbl.Top := 210;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Last RC XP: ' + FormatXP(Settings.LastRunecraftingXP);
  lbl.Left := 10;
  lbl.Top := 235;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Last Magic XP: ' + FormatXP(Settings.LastMagicXP);
  lbl.Left := 10;
  lbl.Top := 260;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Last Mining XP: ' + FormatXP(Settings.LastMiningXP);
  lbl.Left := 10;
  lbl.Top := 285;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  lbl := TLazLabel.CreateEx(statsPanel);
  lbl.Caption := 'Last Crafting XP: ' + FormatXP(Settings.LastCraftingXP);
  lbl.Left := 10;
  lbl.Top := 310;
  lbl.Font.Name := 'Arial';
  lbl.Font.Size := 10;

  Self.Run;
end;

procedure Cleanup;
var
  EndXP, TotalGainedXP: Integer;
begin
  // 1. Terminate and Free Stats Thread
  if StatsThreadInstance <> nil then
  begin
    try
      StatsThreadInstance.Terminate;
      StatsThreadInstance.WaitForTerminate;
    except
      log('Error terminating StatsThread');
    end;

    try
      StatsThreadInstance.Free;
      StatsThreadInstance := nil;
    except
      log('Error freeing StatsThread');
    end;
  end;

  // 2. Terminate and Free GameStateAnalyzer
  try
    GameStateAnalyzer_Terminate;
    GameStateAnalyzer_WaitFor;
  except
    log('Error terminating GameStateAnalyzer');
  end;

  try
    GameStateAnalyzer_Free;
  except
    log('Error freeing GameStateAnalyzer');
  end;

  // 3. Save Settings
  try
    Settings.LastRuntime := GetTimeRunning();

    try
      EndXP := GameState.GetXP();
      if EndXP > 0 then
      begin
        TotalGainedXP := EndXP - StartXP;
        if TotalGainedXP < 0 then TotalGainedXP := 0; // Sanity check

        Settings.LastTotalXP := TotalGainedXP;
        Settings.TotalXP := Settings.TotalXP + TotalGainedXP;

        Settings.LastMiningXP := GameState.GetMiningXP();
        Settings.LastMagicXP := GameState.GetMagicXP();
        Settings.LastCraftingXP := GameState.GetCraftingXP();

        Settings.LastRunecraftingXP := TotalGainedXP - GameState.GetMagicXP() - Settings.LastMiningXP - Settings.LastCraftingXP;
        if Settings.LastRunecraftingXP < 0 then Settings.LastRunecraftingXP := 0; // Sanity check

        Settings.TotalRunecraftingXP := Settings.TotalRunecraftingXP + Settings.LastRunecraftingXP;
        Settings.TotalMagicXP := Settings.TotalMagicXP + Settings.LastMagicXP;
        Settings.TotalMiningXP := Settings.TotalMiningXP + Settings.LastMiningXP;
        Settings.TotalCraftingXP := Settings.TotalCraftingXP + Settings.LastCraftingXP;
      end;
    except
      log('Could not read final XP stats (Client likely closed)');
    end;

    // Persist final stats
    SaveSettings(Settings, SETTINGS_PATH);
  except
    log('Error saving settings during cleanup');
  end;

  // 4. Free Locks
  if StatsLock <> nil then
  begin
    try
      StatsLock.Free;
      StatsLock := nil;
    except
      log('Error freeing StatsLock');
    end;
  end;

  if GameStateLock <> nil then
  begin
    try
      GameStateLock.Free;
      GameStateLock := nil;
    except
      log('Error freeing GameStateLock');
    end;
  end;
end;

procedure Initialize;
begin
  // Register cleanup immediately so locks are freed if initialization fails
  AddOnTerminate(@Cleanup);

  XPBar.Setup();

  ClearSimbaOutput;
  RSClient.EnableRealInput(); //ALLOW FOR MOUSE INPUT
  MouseDefaultSpeed := Random(14,15);  //Real default is 12, but we like speed :)

  StartXP := XPBar.Tracker.Current;
  GameState.FXP := StartXP;
  GameState.FMiningXP := 0;
  GameState.FCraftingXP := 0;
  GameState.FMagicXP := 0;

  GameStateLock := TLock.Create();
  GameStateAnalyzer_Init;
  GameStateAnalyzer_Start;

  StatsLock := TLock.Create();
  StatsThreadInstance := TThread.Create(@RunStatsThread);

  DeclarePlayaz;

  //BMPs declaration, don't forget to clean memory AddOnTerminate
  //PortalArrow := BitmapFromString(3, 4, 'meJxT+v5LCQdiZGCAIACmChKv');
end;

procedure RunMainLoop;
begin
  repeat
    ROOT_IsLoggedInNode;
  until False;
end;

begin

   Form.Setup('GOATER');
   Form.Init();
   Initialize;
   RunMainLoop();
end.


















