Example:
```pascal
ConditionalHeal := MyTree.CreateConditional('Conditional Heal', HealAction, @Self.IsHealthLow);
```
*)
function TBehaviorTree.CreateConditional(Name: String; Child: TBTNodeHandle; ConditionMethod: TBTConditionMethod): TBTNodeHandle; overload;
var
  Node: ^TBTConditionalNode;
begin
  Node := Self._CreateNode(EBTNodeType.Conditional, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Node^.ConditionMethod := @ConditionMethod;
  Result.NodeType := EBTNodeType.Conditional;
