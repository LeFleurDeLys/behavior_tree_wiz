procedure TBehaviorTree.ClearErrors();
begin
  Self.LastError.ErrorType := EBTErrorType.None;
  Self.LastError.Message := '';
  Self.LastError.NodeName := '';
  SetLength(Self.ErrorHistory, 0);
end;

