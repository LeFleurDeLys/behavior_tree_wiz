// Executes repeat until nodes - continues until target condition is met
function TBehaviorTree._ExecuteRepeatUntil(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  RepeatNode: ^TBTRepeatUntilNode;
  ChildStatus: EBTStatus;
begin
  RepeatNode := @Self.RepeatUntilNodes[Handle.Index];
  
  // If MaxTries = 0, fail immediately without executing child
  if RepeatNode^.MaxTries = 0 then
  begin
    if Self.DebugLevel >= EBTDebugLevel.Normal then
    begin
      if RepeatNode^.RepeatUntilSuccess then
        WriteLn(Format('[BT] RepeatUntilSuccess "%s" failed immediately (MaxTries = 0)', [RepeatNode^.Base.Name]))
      else
        WriteLn(Format('[BT] RepeatUntilFailure "%s" failed immediately (MaxTries = 0)', [RepeatNode^.Base.Name]));
    end;
    Exit(EBTStatus.Failure);
  end;
  
  ChildStatus := Self._ExecuteNode(RepeatNode^.Child, Depth + 1);
  
  if RepeatNode^.RepeatUntilSuccess then
  begin
    // RepeatUntilSuccess: continue running until child succeeds
    case ChildStatus of
      EBTStatus.Success: 
      begin
        Result := EBTStatus.Success;
        RepeatNode^.CurrentTries := 0; // Reset counter on success
      end;
      EBTStatus.Failure: 
      begin
        Inc(RepeatNode^.CurrentTries);
        // Check if we've exceeded max tries after incrementing
        if (RepeatNode^.MaxTries > 0) and (RepeatNode^.CurrentTries >= RepeatNode^.MaxTries) then
        begin
          if Self.DebugLevel >= EBTDebugLevel.Normal then
            WriteLn(Format('[BT] RepeatUntilSuccess "%s" exceeded MaxTries (%d)', 
              [RepeatNode^.Base.Name, RepeatNode^.MaxTries]));
          Result := EBTStatus.Failure;
        end
        else
          Result := EBTStatus.Running;
      end;
      EBTStatus.Running: Result := EBTStatus.Running;
    end;
  end
  else
  begin
    // RepeatUntilFailure: continue running until child fails
    case ChildStatus of
      EBTStatus.Success: 
      begin
        Inc(RepeatNode^.CurrentTries);
        // Check if we've exceeded max tries after incrementing
        if (RepeatNode^.MaxTries > 0) and (RepeatNode^.CurrentTries >= RepeatNode^.MaxTries) then
        begin
          if Self.DebugLevel >= EBTDebugLevel.Normal then
            WriteLn(Format('[BT] RepeatUntilFailure "%s" exceeded MaxTries (%d)', 
              [RepeatNode^.Base.Name, RepeatNode^.MaxTries]));
          Result := EBTStatus.Failure;
        end
        else
          Result := EBTStatus.Running;
      end;
      EBTStatus.Failure: 
      begin
        Result := EBTStatus.Success;
        RepeatNode^.CurrentTries := 0; // Reset counter on success
      end;
      EBTStatus.Running: Result := EBTStatus.Running;
    end;
  end;
end;

// Executes delay nodes - waits for specified time before succeeding
function TBehaviorTree._ExecuteDelay(Handle: TBTNodeHandle): EBTStatus;
var
  DelayNode: ^TBTDelayNode;
  CurrentTime: Int64;
begin
  DelayNode := @Self.DelayNodes[Handle.Index];
  CurrentTime := Time();
  
  if DelayNode^.StartTime = 0 then
  begin
    DelayNode^.StartTime := CurrentTime;
    Result := EBTStatus.Running;
  end
  else if (CurrentTime - DelayNode^.StartTime) >= DelayNode^.DelayMS then
  begin
    DelayNode^.StartTime := 0;
    Result := EBTStatus.Success;
  end
  else
  begin
    Result := EBTStatus.Running;
  end;
end;

// Executes static condition nodes - returns fixed result
function TBehaviorTree._ExecuteStaticCondition(Handle: TBTNodeHandle): EBTStatus;
var
  StaticNode: ^TBTStaticConditionNode;
begin
  StaticNode := @Self.StaticConditionNodes[Handle.Index];
  Result := StaticNode^.StaticResult;
end;

// Executes probability nodes - returns success/failure based on random chance
function TBehaviorTree._ExecuteProbability(Handle: TBTNodeHandle): EBTStatus;
var
  ProbNode: ^TBTProbabilityNode;
begin
  ProbNode := @Self.ProbabilityNodes[Handle.Index];
  if Random() <= ProbNode^.SuccessChance then
    Result := EBTStatus.Success
  else
    Result := EBTStatus.Failure;
end;

(*
### TBehaviorTree.GetRemainingTries
```pascal
function TBehaviorTree.GetRemainingTries(Handle: TBTNodeHandle): Integer;
```
Returns remaining tries for a RepeatUntil node. Returns -1 for unlimited.

Example:
```pascal
Remaining := MyTree.GetRemainingTries(RetryNode);
if Remaining > 0 then
  WriteLn('Attempts remaining: ', Remaining);
```
*)
function TBehaviorTree.GetRemainingTries(Handle: TBTNodeHandle): Integer;
var
  RepeatNode: ^TBTRepeatUntilNode;
begin
  if Handle.NodeType in [EBTNodeType.RepeatUntilSuccess, EBTNodeType.RepeatUntilFailure] then
  begin
    RepeatNode := @Self.RepeatUntilNodes[Handle.Index];
    if RepeatNode^.MaxTries <= 0 then
      Result := -1 // Unlimited
    else
      Result := RepeatNode^.MaxTries - RepeatNode^.CurrentTries;
  end
  else
    Result := 0;
end; 

(* FEATURES *)

(*
## Features
Behavior tree features including event system and debugging tools.

These features provide specialized functionality for complex behavior trees.
Use basic blackboard operations for most communication needs.
*)


(*
### CreateWaitForEvent
```pascal
function TBehaviorTree.CreateWaitForEvent(Name: String; EventName: String): TBTNodeHandle;
```
Creates a node that waits for a specific event.

Example:
```pascal
CombatTrigger := Tree.CreateWaitForEvent('WaitForCombat', 'player_entered_combat');
```
*)
function TBehaviorTree.CreateWaitForEvent(Name: String; EventName: String): TBTNodeHandle;
var
  Node: ^TBTWaitForEventNode;
begin
  Node := Self._CreateNode(EBTNodeType.WaitForEvent, Result.Index);
  Node^.Base.Name := Name;
  Node^.EventName := EventName;
  Node^.IsListening := False;
  Node^.EventReceived := False;
  Result.NodeType := EBTNodeType.WaitForEvent;
end;

(*
### CreateBroadcastEvent
```pascal
function TBehaviorTree.CreateBroadcastEvent(Name: String; EventName: String; Data: Variant): TBTNodeHandle;
```
Creates a node that broadcasts an event.

Example:
```pascal
HealthBroadcast := Tree.CreateBroadcastEvent('HealthAlert', 'health_changed', CurrentHealth);
```
*)
function TBehaviorTree.CreateBroadcastEvent(Name: String; EventName: String; Data: Variant): TBTNodeHandle;
var
  Node: ^TBTBroadcastEventNode;
begin
  Node := Self._CreateNode(EBTNodeType.BroadcastEvent, Result.Index);
  Node^.Base.Name := Name;
  Node^.EventName := EventName;
  Node^.EventData := Data;
  Result.NodeType := EBTNodeType.BroadcastEvent;
end;

(*
### CreateEventCondition
```pascal
function TBehaviorTree.CreateEventCondition(Name: String; EventName: String; ConsumeEvent: Boolean = False): TBTNodeHandle;
```
Creates a condition that checks if an event occurred.

Example:
```pascal
EnemySpotted := Tree.CreateEventCondition('CheckEnemySpotted', 'enemy_spotted');
```
*)
function TBehaviorTree.CreateEventCondition(Name: String; EventName: String; ConsumeEvent: Boolean = False): TBTNodeHandle;
var
  Node: ^TBTEventConditionNode;
begin
  Node := Self._CreateNode(EBTNodeType.EventCondition, Result.Index);
  Node^.Base.Name := Name;
  Node^.EventName := EventName;
  Node^.ConsumeEvent := ConsumeEvent;
  Result.NodeType := EBTNodeType.EventCondition;
end;

// Internal event node execution methods
function TBehaviorTree._ExecuteWaitForEvent(Handle: TBTNodeHandle): EBTStatus;
var
  EventNode: ^TBTWaitForEventNode;
begin
  EventNode := @Self.WaitForEventNodes[Handle.Index];
  
  if not EventNode^.IsListening then
  begin
    if Self.DebugLevel in [EBTDebugLevel.Normal, EBTDebugLevel.Verbose] then
      WriteLn(Format('[EVENT] %s is now listening for "%s" event...', [EventNode^.Base.Name, EventNode^.EventName]));
    EventNode^.IsListening := True;
    EventNode^.EventReceived := False;
  end;
  
  // Always check if the event has occurred while listening
  if Self.HasEventOccurred(EventNode^.EventName) then
  begin
    if not EventNode^.EventReceived then // To avoid spamming logs
    begin
        if Self.DebugLevel in [EBTDebugLevel.Normal, EBTDebugLevel.Verbose] then
            WriteLn(Format('[EVENT] %s found "%s" event in blackboard!', [EventNode^.Base.Name, EventNode^.EventName]));
        EventNode^.EventReceived := True;
        EventNode^.EventData := Self.Blackboard.Get(EventNode^.EventName);
    end;
  end;
  
  if EventNode^.EventReceived then
  begin
    if Self.DebugLevel in [EBTDebugLevel.Normal, EBTDebugLevel.Verbose] then
      WriteLn(Format('[EVENT] %s received "%s" event! Resuming behavior.', [EventNode^.Base.Name, EventNode^.EventName]));
    EventNode^.IsListening := False;
    EventNode^.EventReceived := False;
    Result := EBTStatus.Success;
  end
  else
  begin
    Result := EBTStatus.Running;
  end;
end;

function TBehaviorTree._ExecuteBroadcastEvent(Handle: TBTNodeHandle): EBTStatus;
var
  EventNode: ^TBTBroadcastEventNode;
begin
  EventNode := @Self.BroadcastEventNodes[Handle.Index];
  
  if Self.DebugLevel in [EBTDebugLevel.Normal, EBTDebugLevel.Verbose] then
    WriteLn(Format('[EVENT] %s broadcasting "%s" event with data: %s', [EventNode^.Base.Name, EventNode^.EventName, ToStr(EventNode^.EventData)]));
    
  Self.BroadcastEvent(EventNode^.EventName, EventNode^.EventData);
  Result := EBTStatus.Success;
end;

function TBehaviorTree._ExecuteEventCondition(Handle: TBTNodeHandle): EBTStatus;
var
  EventNode: ^TBTEventConditionNode;
  EventKey: String;
begin
  EventNode := @Self.EventConditionNodes[Handle.Index];
  EventKey := EventNode^.EventName;  
  
  if Self.Blackboard.HasKey(EventKey) then
  begin
    if EventNode^.ConsumeEvent then
    begin
      Self.Blackboard.RemoveKey(EventKey);  
    end;
    Result := EBTStatus.Success;
  end
  else
    Result := EBTStatus.Failure;
end;

// Internal state change notification
procedure TBehaviorTree._EmitStateChanged();
begin
  // Signal that the behavior tree state has changed
  Self.Blackboard.Put('_bt_state_changed', True);
  Self.Blackboard.Put('_bt_event_counter', Self.Blackboard.Get('_bt_event_counter', 0) + 1);
end;

(*
### TriggerEvent
```pascal
procedure TBehaviorTree.TriggerEvent(EventName: String; Data: Variant);
```
Triggers an event with data.

Example:
```pascal
Tree.TriggerEvent('player_entered_combat', True);
```
*)
procedure TBehaviorTree.TriggerEvent(EventName: String; Data: Variant);
begin
  Self.Blackboard.Put(EventName, Data);
  Self._EmitStateChanged();
end;

(*
### TriggerPriorityEvent
```pascal
procedure TBehaviorTree.TriggerPriorityEvent(EventName: String; Data: Variant);
```
Triggers a priority event that interrupts current behavior.

Example:
```pascal
Tree.TriggerPriorityEvent('taking_damage', DamageAmount);
```
*)
procedure TBehaviorTree.TriggerPriorityEvent(EventName: String; Data: Variant);
begin
  Self.TriggerEvent(EventName, Data);
  Self.InterruptRequested := True;
  Self.InterruptReason := EventName;
end;

(*
### ConsumeEvent
```pascal
function TBehaviorTree.ConsumeEvent(EventName: String): Variant;
```
Retrieves and removes an event.

Example:
```pascal
LootData := Tree.ConsumeEvent('loot_available');
```
*)
function TBehaviorTree.ConsumeEvent(EventName: String): Variant;
begin
  if Self.Blackboard.HasKey(EventName) then
  begin
    Result := Self.Blackboard.Get(EventName);
    Self.Blackboard.RemoveKey(EventName);
  end else
    Result := nil;
end;

(*
### BroadcastEvent
```pascal
procedure TBehaviorTree.BroadcastEvent(EventName: String; Data: Variant);
```
Broadcasts an event (alias for TriggerEvent).

Example:
```pascal
Tree.BroadcastEvent('objective_completed', ObjectiveId);
```
*)
procedure TBehaviorTree.BroadcastEvent(EventName: String; Data: Variant);
begin
  Self.TriggerEvent(EventName, Data);
end;

(*
### HasEventOccurred
```pascal
function TBehaviorTree.HasEventOccurred(EventName: String): Boolean;
```
Checks if an event occurred without consuming it.

Example:
```pascal
if Tree.HasEventOccurred('combat_ended') then
  WriteLn('Combat ended');
```
*)
function TBehaviorTree.HasEventOccurred(EventName: String): Boolean;
begin
  Result := Self.Blackboard.HasKey(EventName);
end;

// Internal error handling with enhanced context
procedure TBehaviorTree.SetError(ErrorType: EBTErrorType; Message: String; NodeName: String);
var
  FullMessage, EnhancedMessage: String;
  KeyList: TStringArray;
  i: Integer;
begin
  Self.LastError.ErrorType := ErrorType;
  Self.LastError.NodeName := NodeName;
  Self.LastError.Timestamp := Time();
  
  EnhancedMessage := Message;
  
  case ErrorType of
    EBTErrorType.BlackboardError:
      begin
        EnhancedMessage := Message;
        KeyList := Self.Blackboard.GetKeys();
        if Length(KeyList) > 0 then
        begin
          EnhancedMessage := EnhancedMessage + '. Available keys: ';
          for i := 0 to High(KeyList) do
          begin
            if i > 0 then EnhancedMessage := EnhancedMessage + ', ';
            EnhancedMessage := EnhancedMessage + KeyList[i].ToUpper();
          end;
        end;
      end;
    // Other error types use the message as-is for clean, concise output
  end;
  
  if NodeName <> '' then
    FullMessage := Format('%s (Node: "%s")', [EnhancedMessage, NodeName])
  else
    FullMessage := EnhancedMessage;
  
  Self.LastError.Message := FullMessage;
  
  if Self.DebugLevel <> EBTDebugLevel.Silent then
  begin
    WriteLn(Format('[BT ERROR] %s', [FullMessage]));
  end;
  
  // Store in error history
  if Length(Self.ErrorHistory) >= 50 then
  begin
    Move(Self.ErrorHistory[1], Self.ErrorHistory[0], (Length(Self.ErrorHistory) - 1) * SizeOf(TBTError));
    Self.ErrorHistory[High(Self.ErrorHistory)] := Self.LastError;
  end else
  begin
    SetLength(Self.ErrorHistory, Length(Self.ErrorHistory) + 1);
    Self.ErrorHistory[High(Self.ErrorHistory)] := Self.LastError;
  end;
end;

