// Gets the children array from a composite node handle
function TBehaviorTree._GetNodeChildren(Handle: TBTNodeHandle): PBTNodeHandleArray;
begin
  Result := nil;
  if Handle.Index < 0 then Exit;
  case Handle.NodeType of
    EBTNodeType.Selector: if Handle.Index < Length(Self.SelectorNodes) then Result := @Self.SelectorNodes[Handle.Index].Children;
    EBTNodeType.Sequence: if Handle.Index < Length(Self.SequenceNodes) then Result := @Self.SequenceNodes[Handle.Index].Children;
    EBTNodeType.ParallelSequence: if Handle.Index < Length(Self.ParallelSequenceNodes) then Result := @Self.ParallelSequenceNodes[Handle.Index].Children;
    EBTNodeType.ParallelSelector: if Handle.Index < Length(Self.ParallelSelectorNodes) then Result := @Self.ParallelSelectorNodes[Handle.Index].Children;
    EBTNodeType.RandomSelector: if Handle.Index < Length(Self.RandomSelectorNodes) then Result := @Self.RandomSelectorNodes[Handle.Index].Children;
    EBTNodeType.WeightedSelector: if Handle.Index < Length(Self.WeightedSelectorNodes) then Result := @Self.WeightedSelectorNodes[Handle.Index].Children;
    EBTNodeType.BlackboardSelector: if Handle.Index < Length(Self.BlackboardSelectorNodes) then Result := @Self.BlackboardSelectorNodes[Handle.Index].Children;
    EBTNodeType.ReactiveSelector: if Handle.Index < Length(Self.ReactiveSelectorNodes) then Result := @Self.ReactiveSelectorNodes[Handle.Index].Children;
    EBTNodeType.ReactiveSequence: if Handle.Index < Length(Self.ReactiveSequenceNodes) then Result := @Self.ReactiveSequenceNodes[Handle.Index].Children;
  end;
end;

function TBehaviorTree._GetNodeChild(Handle: TBTNodeHandle): TBTNodeHandle;
begin
  Result.Index := -1;
  if Handle.Index < 0 then Exit;
  case Handle.NodeType of
    EBTNodeType.Inverter: if Handle.Index < Length(Self.InverterNodes) then Result := Self.InverterNodes[Handle.Index].Child;
    EBTNodeType.ForceSuccess: if Handle.Index < Length(Self.ForceSuccessNodes) then Result := Self.ForceSuccessNodes[Handle.Index].Child;
    EBTNodeType.ForceFailure: if Handle.Index < Length(Self.ForceFailureNodes) then Result := Self.ForceFailureNodes[Handle.Index].Child;
    EBTNodeType.Retry: if Handle.Index < Length(Self.RetryNodes) then Result := Self.RetryNodes[Handle.Index].Child;
    EBTNodeType.Cooldown: if Handle.Index < Length(Self.CooldownNodes) then Result := Self.CooldownNodes[Handle.Index].Child;
    EBTNodeType.Timeout: if Handle.Index < Length(Self.TimeoutNodes) then Result := Self.TimeoutNodes[Handle.Index].Child;
    EBTNodeType.Conditional: if Handle.Index < Length(Self.ConditionalNodes) then Result := Self.ConditionalNodes[Handle.Index].Child;
    EBTNodeType.Repeater: if Handle.Index < Length(Self.RepeaterNodes) then Result := Self.RepeaterNodes[Handle.Index].Child;
    EBTNodeType.RepeatUntilSuccess, EBTNodeType.RepeatUntilFailure: if Handle.Index < Length(Self.RepeatUntilNodes) then Result := Self.RepeatUntilNodes[Handle.Index].Child;
    EBTNodeType.Link: if Handle.Index < Length(Self.LinkNodes) then Result := Self.LinkNodes[Handle.Index].TargetNode;
  end;
end;

// Gets the display name from a node handle
function TBehaviorTree._GetNodeName(Handle: TBTNodeHandle): String;
var
  NodeBase: ^TBTNodeBase;
begin
  NodeBase := Self._GetNodeBase(Handle);
  if NodeBase <> nil then
    Result := NodeBase^.Name
  else
    Result := 'Unknown';
end;

// Converts status enum to display icon
function TBehaviorTree._GetStatusIcon(Status: EBTStatus): String;
begin
  case Status of
    EBTStatus.Success: Result := '[OK]';
    EBTStatus.Failure: Result := '[FAIL]';
    EBTStatus.Running: Result := '[RUN]';
    else Result := '[?]';
  end;
end;

// Converts status enum to string
function TBehaviorTree._StatusToString(Status: EBTStatus): String;
begin
  case Status of
    EBTStatus.Success: Result := 'SUCCESS';
    EBTStatus.Failure: Result := 'FAILURE';
    EBTStatus.Running: Result := 'RUNNING';
    else Result := 'UNKNOWN';
  end;
end;

(*
### TBehaviorTree.Tick
```pascal
function TBehaviorTree.Tick(): EBTStatus;
```
Executes the behavior tree by running the root node.

Example:
```pascal
Status := MyTree.Tick();
```
*)
function TBehaviorTree.Tick(): EBTStatus;
var
  PreviousStatusInt: Integer;
  StatusChanged: Boolean;
begin
  if not Assigned(@Self.Lock) then
    Self.Setup('DefaultTree');
  if Self.Root.Index < 0 then
  begin
    Self.SetError(EBTErrorType.NullReference, 'Root node is not set', '');
    Exit(EBTStatus.Failure);
  end;
  
  PreviousStatusInt := Self.Blackboard.Get('_bt_last_status', 0);
  
  Self.CurrentExecutionDepth := 0;
  Result := Self._ExecuteNode(Self.Root, 0);
  
  StatusChanged := (Integer(Result) <> PreviousStatusInt);
  if StatusChanged then
  begin
    Self.Blackboard.Put('_bt_last_status', Integer(Result));
    Self._EmitStateChanged();
  end;
end;

// Recursively executes a node and its children, handling all node types
function TBehaviorTree._ExecuteNode(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  StartTime: Double;
  NodeBase: ^TBTNodeBase;
  NodeState: ^TBTNodeState;
begin
  if (Handle.Index < 0) then
  begin
    Self.SetError(EBTErrorType.NullReference, 'Node handle is invalid', '');
    Exit(EBTStatus.Failure);
  end;

  NodeBase := Self._GetNodeBase(Handle);
  NodeState := Self._GetNodeState(Handle);

  if (NodeBase = nil) or (NodeState = nil) then
  begin
      Self.SetError(EBTErrorType.InvalidNode, 'Failed to get node from handle', '');
      Exit(EBTStatus.Failure);
  end;

  if Depth >= BT_MAX_RECURSION_DEPTH then
  begin
    Self.SetError(EBTErrorType.MaxDepthExceeded, 'Maximum recursion depth exceeded', NodeBase^.Name);
    Exit(EBTStatus.Failure);
  end;

  if Self.InterruptRequested then
  begin
    if Self.DebugLevel >= EBTDebugLevel.Normal then
      WriteLn(Format('[INTERRUPT] Node "%s" interrupted by priority event: %s', [NodeBase^.Name, Self.InterruptReason]));
    Self.InterruptRequested := False;
    Exit(EBTStatus.Failure);
  end;

  // Only initialize timing if needed for debugging
  if Self.DebugLevel = EBTDebugLevel.Verbose then
    StartTime := PerformanceTime();

  if Self.DebugLevel in [EBTDebugLevel.Normal, EBTDebugLevel.Verbose] then
    WriteLn(Format('%s--> %s', [''.PadLeft(Depth * 2), NodeBase^.Name]));

  Inc(NodeState^.ExecutionCount);

  case Handle.NodeType of
    EBTNodeType.Action: Result := Self._ExecuteAction(Handle);
    EBTNodeType.Selector, EBTNodeType.Sequence, EBTNodeType.RandomSelector: Result := Self._ExecuteComposite(Handle, Depth);
    EBTNodeType.Inverter, EBTNodeType.ForceSuccess, EBTNodeType.ForceFailure: Result := Self._ExecuteDecorator(Handle, Depth);
    EBTNodeType.ParallelSelector: Result := Self._HandleParallelNode(Handle, Depth);
    EBTNodeType.ParallelSequence: Result := Self._HandleParallelNode(Handle, Depth);
    EBTNodeType.Retry: Result := Self._ExecuteRetry(Handle, Depth);
    EBTNodeType.Cooldown, EBTNodeType.Timeout: Result := Self._ExecuteTimer(Handle, Depth);
    EBTNodeType.BlackboardCondition: Result := Self._ExecuteBlackboardCondition(Handle);
    EBTNodeType.Conditional: Result := Self._ExecuteConditional(Handle, Depth);
    EBTNodeType.Condition: Result := Self._ExecuteCondition(Handle);
    EBTNodeType.WeightedSelector: Result := Self._ExecuteWeightedSelector(Handle, Depth);
    EBTNodeType.BlackboardSelector: Result := Self._ExecuteBlackboardSelector(Handle, Depth);
    EBTNodeType.Repeater: Result := Self._ExecuteRepeater(Handle, Depth);
    EBTNodeType.Subtree: Result := Self._ExecuteSubtree(Handle, Depth);
    EBTNodeType.Link: Result := Self._ExecuteLink(Handle, Depth);
    EBTNodeType.WaitForEvent: Result := Self._ExecuteWaitForEvent(Handle);
    EBTNodeType.BroadcastEvent: Result := Self._ExecuteBroadcastEvent(Handle);
    EBTNodeType.EventCondition: Result := Self._ExecuteEventCondition(Handle);
    EBTNodeType.ReactiveSelector: Result := Self._ExecuteReactiveComposite(Handle, Depth);
    EBTNodeType.ReactiveSequence: Result := Self._ExecuteReactiveComposite(Handle, Depth);
    EBTNodeType.DataGatherer: Result := Self._ExecuteDataGatherer(Handle);
    EBTNodeType.RepeatUntilSuccess: Result := Self._ExecuteRepeatUntil(Handle, Depth);
    EBTNodeType.RepeatUntilFailure: Result := Self._ExecuteRepeatUntil(Handle, Depth);
    EBTNodeType.Delay: Result := Self._ExecuteDelay(Handle);
    EBTNodeType.Success: Result := Self._ExecuteStaticCondition(Handle);
    EBTNodeType.Failure: Result := Self._ExecuteStaticCondition(Handle);
    EBTNodeType.Running: Result := Self._ExecuteStaticCondition(Handle);
    EBTNodeType.Probability: Result := Self._ExecuteProbability(Handle);
    else
    begin
      Self.SetError(EBTErrorType.InvalidNode, 'Unknown or unhandled node type: ' + ToStr(Handle.NodeType), NodeBase^.Name);
      Result := EBTStatus.Failure;
    end;
  end;

  if Self.DebugLevel = EBTDebugLevel.Verbose then
    Self._AddTraceEntry(''.PadLeft(Depth, '/') + NodeBase^.Name, NodeBase^.Name, Result, PerformanceTime() - StartTime, Depth);
  if Self.DebugLevel in [EBTDebugLevel.Normal, EBTDebugLevel.Verbose] then
    WriteLn(Format('%s<-- %s %s', [''.PadLeft(Depth * 2), NodeBase^.Name, Self._GetStatusIcon(Result)]));
end;

(*
### TBehaviorTree.Setup
```pascal
procedure TBehaviorTree.Setup(TreeName: String);
```
Initializes the behavior tree with default settings.

Example:
```pascal
MyTree.Setup('AI Controller');
```
*)
procedure TBehaviorTree.Setup(TreeName: String);
begin
  Self.Name := TreeName;
  Self.Blackboard.Setup();
  Self.DefaultParallelTimeoutMS := 10000;
  Self.Lock := TLock.Create();
  Self.OwnerOfLock := True;
  Self.OwnerOfBlackboard := True;
  Self.DebugLevel := EBTDebugLevel.Errors;
  Self.MaxTraceSize := 100;
  Self.CurrentExecutionDepth := 0;
  Self.Root.Index := -1;
  Self.Root.NodeType := EBTNodeType.Action;
  Self.InterruptRequested := False;
  Self.InterruptReason := '';
end;

(*
### TBehaviorTree.Free
```pascal
procedure TBehaviorTree.Free();
```
Cleans up all resources used by the behavior tree.

Example:
```pascal
MyTree.Free();
```
*)
procedure TBehaviorTree.Free();
var
  i: Integer;
begin
  for i := 0 to High(Self.Subtrees) do
    if Self.Subtrees[i] <> nil then
    begin
      Self.Subtrees[i]^.Free();
      Dispose(Self.Subtrees[i]);
      Self.Subtrees[i] := nil;
    end;
  if Self.ParallelEnabled then
    Self.ThreadManager.Free();
  if Self.OwnerOfBlackboard then
    Self.Blackboard.Free();
  if Self.OwnerOfLock and Assigned(@Self.Lock) then
    Self.Lock.Free();
end;

(*
### TBehaviorTree.SetDebugLevel
```pascal
procedure TBehaviorTree.SetDebugLevel(Level: EBTDebugLevel);
```
Sets the debug verbosity level.

Example:
```pascal
MyTree.SetDebugLevel(EBTDebugLevel.Verbose); // Detailed logging
MyTree.SetDebugLevel(EBTDebugLevel.Silent);  // No logging
```
*)
procedure TBehaviorTree.SetDebugLevel(Level: EBTDebugLevel);
begin
  Self.DebugLevel := Level;
  if Level = EBTDebugLevel.Verbose then
    Self.Blackboard.EnableTracing := True
  else
    Self.Blackboard.EnableTracing := False;
end; 

(* ACTIONS *)

(*
## Actions
Action and condition nodes for behavior trees.

Actions execute functions and return success/failure/running.
Conditions evaluate boolean expressions and return success/failure.
Blackboard conditions compare stored values for data-driven behavior.
*)



(*
### TBehaviorTree.CreateAction
```pascal
function TBehaviorTree.CreateAction(Name: String; ActionFunc: TBTAction): TBTNodeHandle;
```
Creates an action node that executes a function.

Example:
```pascal
ActionNode := MyTree.CreateAction('Attack', @DoAttack);
```
*)
function TBehaviorTree.CreateAction(Name: String; ActionFunc: TBTAction): TBTNodeHandle;
var
  Node: ^TBTActionNode;
begin
  Node := Self._CreateNode(EBTNodeType.Action, Result.Index);
  Node^.Base.Name := Name;
  Node^.Action := @ActionFunc;
  Result.NodeType := EBTNodeType.Action;
end;

(*
### TBehaviorTree.CreateAction
```pascal
function TBehaviorTree.CreateAction(Name: String; ActionMethod: TBTActionMethod): TBTNodeHandle;
```
Creates an action node that executes a method.

Example:
```pascal
ActionNode := MyTree.CreateAction('Attack', @Self.DoAttack);
```
*)
function TBehaviorTree.CreateAction(Name: String; ActionMethod: TBTActionMethod): TBTNodeHandle; overload;
var
  Node: ^TBTActionNode;
begin
  Node := Self._CreateNode(EBTNodeType.Action, Result.Index);
  Node^.Base.Name := Name;
  Node^.ActionMethod := @ActionMethod;
  Result.NodeType := EBTNodeType.Action;
end;

(*
### TBehaviorTree.CreateCondition
```pascal
function TBehaviorTree.CreateCondition(Name: String; ConditionFunc: TBTCondition): TBTNodeHandle;
```
Creates a condition node that evaluates a function.

Example:
```pascal
ConditionNode := MyTree.CreateCondition('Enemy Nearby', @IsEnemyNearby);
```
*)
function TBehaviorTree.CreateCondition(Name: String; ConditionFunc: TBTCondition): TBTNodeHandle;
var
  Node: ^TBTConditionNode;
begin
  Node := Self._CreateNode(EBTNodeType.Condition, Result.Index);
  Node^.Base.Name := Name;
  Node^.Condition := @ConditionFunc;
  Result.NodeType := EBTNodeType.Condition;
end;

(*
### TBehaviorTree.CreateCondition
```pascal
function TBehaviorTree.CreateCondition(Name: String; ConditionMethod: TBTConditionMethod): TBTNodeHandle;
```
Creates a condition node that evaluates a method.

Example:
```pascal
ConditionNode := MyTree.CreateCondition('Health Low', @Self.IsHealthLow);
```
*)
function TBehaviorTree.CreateCondition(Name: String; ConditionMethod: TBTConditionMethod): TBTNodeHandle; overload;
var
  Node: ^TBTConditionNode;
begin
  Node := Self._CreateNode(EBTNodeType.Condition, Result.Index);
  Node^.Base.Name := Name;
  Node^.ConditionMethod := @ConditionMethod;
  Result.NodeType := EBTNodeType.Condition;
end;

(*
### TBehaviorTree.CreateBlackboardCondition
```pascal
function TBehaviorTree.CreateBlackboardCondition(Name: String; Key: String; AOperator: EBBOperator; Value: Variant): TBTNodeHandle;
```
Creates a condition that compares a blackboard value.

Example:
```pascal
// Check if health > 50
HealthCheck := MyTree.CreateBlackboardCondition('Health Check', 'Health', EBBOperator.GreaterThan, 50);
```
*)
function TBehaviorTree.CreateBlackboardCondition(Name: String; Key: String; AOperator: EBBOperator; Value: Variant): TBTNodeHandle;
var
  Node: ^TBTBlackboardConditionNode;
  KeyCheck: String;
begin
  KeyCheck := Self.Blackboard._CheckKey(Key);
  if KeyCheck <> '' then
    WriteLn(Format('[BT WARNING] BlackboardCondition "%s": %s', [Name, KeyCheck]));
  
  Node := Self._CreateNode(EBTNodeType.BlackboardCondition, Result.Index);
  Node^.Base.Name := Name;
  Node^.BlackboardKey := Key;
  Node^.BlackboardOperator := AOperator;
  Node^.CompareValue := Value;
  Result.NodeType := EBTNodeType.BlackboardCondition;
end;

// Executes an action node and returns its status
function TBehaviorTree._ExecuteAction(Handle: TBTNodeHandle): EBTStatus;
var
  ActionNode: ^TBTActionNode;
begin
  ActionNode := @Self.ActionNodes[Handle.Index];
  if not Assigned(@ActionNode^.Action) and not Assigned(@ActionNode^.ActionMethod) then
  begin
    Self.SetError(EBTErrorType.InvalidNode, 'Action node has no assigned function', ActionNode^.Base.Name);
    Exit(EBTStatus.Failure);
  end;
  if Assigned(@ActionNode^.Action) then
    Result := ActionNode^.Action()
  else
    Result := ActionNode^.ActionMethod();
end;

// Executes a condition node and returns success/failure based on condition result
function TBehaviorTree._ExecuteCondition(Handle: TBTNodeHandle): EBTStatus;
var
  CondNode: ^TBTConditionNode;
begin
  CondNode := @Self.ConditionNodes[Handle.Index];
  if Assigned(@CondNode^.Condition) then
  begin
    if CondNode^.Condition() then Result := EBTStatus.Success else Result := EBTStatus.Failure;
  end else if Assigned(@CondNode^.ConditionMethod) then
  begin
    if CondNode^.ConditionMethod() then Result := EBTStatus.Success else Result := EBTStatus.Failure;
  end else
    Result := EBTStatus.Failure;
end;

// Executes a blackboard condition node by comparing blackboard value with stored value
function TBehaviorTree._ExecuteBlackboardCondition(Handle: TBTNodeHandle): EBTStatus;
var
  BBNode: ^TBTBlackboardConditionNode;
begin
  BBNode := @Self.BlackboardConditionNodes[Handle.Index];
  if Self.Blackboard.Compare(BBNode^.BlackboardKey, BBNode^.BlackboardOperator, BBNode^.CompareValue) then
    Result := EBTStatus.Success
  else
    Result := EBTStatus.Failure;
end; 

(* COMPOSITES *)

(*
## Composites
Composite nodes for behavior trees.

Selector nodes execute children until one succeeds (OR logic).
Sequence nodes execute children until one fails (AND logic).
Parallel nodes execute all children simultaneously.
*)



(*
### TBehaviorTree.CreateSelector
```pascal
function TBehaviorTree.CreateSelector(Name: String; Children: TBTNodeHandleArray = []; HasMemory: Boolean = False): TBTNodeHandle;
```
Creates a selector that tries children until one succeeds.

Example:
```pascal
Selector := MyTree.CreateSelector('Combat', [Attack, Defend, Flee]);
Selector := MyTree.CreateSelector('Empty Selector'); // Empty selector
```
*)
function TBehaviorTree.CreateSelector(Name: String; Children: TBTNodeHandleArray = []; HasMemory: Boolean = False): TBTNodeHandle;
var
  Node: ^TBTCompositeNode;
begin
  Node := Self._CreateNode(EBTNodeType.Selector, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  Node^.HasMemory := HasMemory;
  Result.NodeType := EBTNodeType.Selector;
end;

(*
### TBehaviorTree.CreateSequence
```pascal
function TBehaviorTree.CreateSequence(Name: String; Children: TBTNodeHandleArray = []; HasMemory: Boolean = False): TBTNodeHandle;
```
Creates a sequence that executes children until one fails.

Example:
```pascal
Sequence := MyTree.CreateSequence('Attack Combo', [Aim, Fire, Reload]);
Sequence := MyTree.CreateSequence('Empty Sequence'); // Empty sequence
```
*)
function TBehaviorTree.CreateSequence(Name: String; Children: TBTNodeHandleArray = []; HasMemory: Boolean = False): TBTNodeHandle;
var
  Node: ^TBTCompositeNode;
begin
  Node := Self._CreateNode(EBTNodeType.Sequence, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  Node^.HasMemory := HasMemory;
  Result.NodeType := EBTNodeType.Sequence;
end;

(*
### TBehaviorTree.CreateRandomSelector
```pascal
function TBehaviorTree.CreateRandomSelector(Name: String; Children: TBTNodeHandleArray = []): TBTNodeHandle;
```
Creates a selector that randomly picks one child each tick.

Example:
```pascal
RandomBehavior := MyTree.CreateRandomSelector('Random Patrol', [Left, Right, Center]);
RandomBehavior := MyTree.CreateRandomSelector('Empty Random'); // Empty random selector
```
*)
function TBehaviorTree.CreateRandomSelector(Name: String; Children: TBTNodeHandleArray = []): TBTNodeHandle;
var
  Node: ^TBTCompositeNode;
begin
  Node := Self._CreateNode(EBTNodeType.RandomSelector, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  Result.NodeType := EBTNodeType.RandomSelector;
end;

(*
### TBehaviorTree.CreateWeightedSelector
```pascal
function TBehaviorTree.CreateWeightedSelector(Name: String; Children: TBTNodeHandleArray = []; Weights: TSingleArray): TBTNodeHandle;
```
Creates a selector that picks children based on weights.

Example:
```pascal
// 70% attack, 20% defend, 10% flee
WeightedCombat := MyTree.CreateWeightedSelector('Combat', [Attack, Defend, Flee], [0.7, 0.2, 0.1]);
WeightedCombat := MyTree.CreateWeightedSelector('Empty Weighted', [], [1.0]); // Empty weighted selector
```
*)
function TBehaviorTree.CreateWeightedSelector(Name: String; Children: TBTNodeHandleArray = []; Weights: TSingleArray): TBTNodeHandle;
var
  Node: ^TBTWeightedSelectorNode;
begin
  Node := Self._CreateNode(EBTNodeType.WeightedSelector, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  Node^.Weights := Weights;
  if (Length(Children) > 0) and (Length(Weights) <> Length(Children)) then
    Self.SetError(EBTErrorType.InvalidNode, 'WeightedSelector weights count must match children count', Name);
  Result.NodeType := EBTNodeType.WeightedSelector;
end;

(*
### TBehaviorTree.CreateBlackboardSelector
```pascal
function TBehaviorTree.CreateBlackboardSelector(Name: String; Key: String; Children: TBTNodeHandleArray = []): TBTNodeHandle;
```
Creates a selector that chooses a child based on blackboard value.

Example:
```pascal
// Blackboard value 'State' determines which child to run
StateSelector := MyTree.CreateBlackboardSelector('State Machine', 'State', [Idle, Combat, Explore]);
StateSelector := MyTree.CreateBlackboardSelector('Empty State', 'State', []); // Empty blackboard selector
```
*)
function TBehaviorTree.CreateBlackboardSelector(Name: String; Key: String; Children: TBTNodeHandleArray = []): TBTNodeHandle;
var
  Node: ^TBTBlackboardSelectorNode;
  KeyCheck: String;
begin
  KeyCheck := Self.Blackboard._CheckKey(Key);
  if KeyCheck <> '' then
    WriteLn(Format('[BT WARNING] BlackboardSelector "%s": %s', [Name, KeyCheck]));
  
  Node := Self._CreateNode(EBTNodeType.BlackboardSelector, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  Node^.BlackboardKey := Key;
  Result.NodeType := EBTNodeType.BlackboardSelector;
end;

(*
### TBehaviorTree.CreateParallelSelector
```pascal
function TBehaviorTree.CreateParallelSelector(Name: String; Children: TBTNodeHandleArray = []; TimeoutMS: Integer = 0): TBTNodeHandle;
```
Creates a parallel selector that succeeds when any child succeeds.

Example:
```pascal
ParallelSearch := MyTree.CreateParallelSelector('Search', [SearchLeft, SearchRight]);
ParallelSearch := MyTree.CreateParallelSelector('Empty Parallel'); // Empty parallel selector
```
*)
function TBehaviorTree.CreateParallelSelector(Name: String; Children: TBTNodeHandleArray = []; TimeoutMS: Integer = 0): TBTNodeHandle;
var
  Node: ^TBTParallelNode;
begin
  Node := Self._CreateNode(EBTNodeType.ParallelSelector, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  if TimeoutMS > 0 then
    Node^.ParallelTimeoutMS := TimeoutMS
  else
    Node^.ParallelTimeoutMS := Self.DefaultParallelTimeoutMS;
  if not Self.ParallelEnabled then
  begin
    Self.ParallelEnabled := True;
    Self.ThreadManager.Init(0, EDebugLevel.NONE);
  end;
  Result.NodeType := EBTNodeType.ParallelSelector;
end;

(*
### TBehaviorTree.CreateParallelSequence
```pascal
function TBehaviorTree.CreateParallelSequence(Name: String; Children: TBTNodeHandleArray = []; TimeoutMS: Integer = 0): TBTNodeHandle;
```
Creates a parallel sequence that succeeds when all children succeed.

Example:
```pascal
ParallelPrep := MyTree.CreateParallelSequence('Prep', [LoadWeapon, AimTarget, CheckAmmo]);
ParallelPrep := MyTree.CreateParallelSequence('Empty Parallel Seq'); // Empty parallel sequence
```
*)
function TBehaviorTree.CreateParallelSequence(Name: String; Children: TBTNodeHandleArray = []; TimeoutMS: Integer = 0): TBTNodeHandle;
var
  Node: ^TBTParallelNode;
begin
  Node := Self._CreateNode(EBTNodeType.ParallelSequence, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  if TimeoutMS > 0 then
    Node^.ParallelTimeoutMS := TimeoutMS
  else
    Node^.ParallelTimeoutMS := Self.DefaultParallelTimeoutMS;
  if not Self.ParallelEnabled then
  begin
    Self.ParallelEnabled := True;
    Self.ThreadManager.Init(0, EDebugLevel.NONE);
  end;
  Result.NodeType := EBTNodeType.ParallelSequence;
end;

// Selects a weighted child based on probability distribution
function TBehaviorTree._PickWeightedChild(Handle: TBTNodeHandle): Integer;
var
  i: Integer;
  TotalWeight, RandomValue, CurrentWeight: Single;
  Node: ^TBTWeightedSelectorNode;
begin
  Result := -1;
  Node := @Self.WeightedSelectorNodes[Handle.Index];
  if (Length(Node^.Weights) = 0) then Exit;
  TotalWeight := 0.0;
  for i := 0 to High(Node^.Weights) do
    TotalWeight := TotalWeight + Node^.Weights[i];
  if TotalWeight <= 0.0 then Exit;
  RandomValue := Random() * TotalWeight;
  CurrentWeight := 0.0;
  for i := 0 to High(Node^.Weights) do
  begin
    CurrentWeight := CurrentWeight + Node^.Weights[i];
    if RandomValue < CurrentWeight then
    begin
      Result := i;
      Break;
    end;
  end;
end;

// Executes composite nodes (selector, sequence, random selector)
function TBehaviorTree._ExecuteComposite(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  i, StartIndex: Integer;
  ChildStatus: EBTStatus;
  CompositeNode: ^TBTCompositeNode;
  NodeState: ^TBTNodeState;
begin
  case Handle.NodeType of
    EBTNodeType.Selector: CompositeNode := @Self.SelectorNodes[Handle.Index];
    EBTNodeType.Sequence: CompositeNode := @Self.SequenceNodes[Handle.Index];
    EBTNodeType.RandomSelector: CompositeNode := @Self.RandomSelectorNodes[Handle.Index];
  end;
  NodeState := @CompositeNode^.State;

  if Handle.NodeType = EBTNodeType.RandomSelector then
  begin
    if Length(CompositeNode^.Children) > 0 then
    begin
      i := Random(Length(CompositeNode^.Children));
      Result := Self._ExecuteNode(CompositeNode^.Children[i], Depth + 1);
    end else Result := EBTStatus.Failure;
    Exit;
  end;

  StartIndex := 0;
  if CompositeNode^.HasMemory and (NodeState^.RunningChildIndex > -1) then
    StartIndex := NodeState^.RunningChildIndex;

  for i := StartIndex to High(CompositeNode^.Children) do
  begin
    ChildStatus := Self._ExecuteNode(CompositeNode^.Children[i], Depth + 1);
    if (Handle.NodeType = EBTNodeType.Selector) and (ChildStatus <> EBTStatus.Failure) then
    begin
      if ChildStatus = EBTStatus.Running then NodeState^.RunningChildIndex := i else NodeState^.RunningChildIndex := -1;
      Exit(ChildStatus);
    end;
    if (Handle.NodeType = EBTNodeType.Sequence) and (ChildStatus <> EBTStatus.Success) then
    begin
      if ChildStatus = EBTStatus.Running then NodeState^.RunningChildIndex := i else NodeState^.RunningChildIndex := -1;
      Exit(ChildStatus);
    end;
  end;
  NodeState^.RunningChildIndex := -1;
  if Handle.NodeType = EBTNodeType.Selector then Result := EBTStatus.Failure else Result := EBTStatus.Success;
end;

// Executes weighted selector nodes by picking a child based on weights
function TBehaviorTree._ExecuteWeightedSelector(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  i: Integer;
  WSNode: ^TBTWeightedSelectorNode;
begin
  WSNode := @Self.WeightedSelectorNodes[Handle.Index];
  if Length(WSNode^.Children) > 0 then
  begin
    i := Self._PickWeightedChild(Handle);
    if (i >= 0) then
      Result := Self._ExecuteNode(WSNode^.Children[i], Depth + 1)
    else
      Result := EBTStatus.Failure;
  end else
    Result := EBTStatus.Failure;
end;

// Executes blackboard selector nodes by using blackboard value as child index
function TBehaviorTree._ExecuteBlackboardSelector(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  i: Integer;
  BSNode: ^TBTBlackboardSelectorNode;
begin
  BSNode := @Self.BlackboardSelectorNodes[Handle.Index];
  if (BSNode^.BlackboardKey <> '') and (Length(BSNode^.Children) > 0) then
  begin
    i := Self.Blackboard.Get(BSNode^.BlackboardKey, -1);
    if (i >= 0) and (i < Length(BSNode^.Children)) then
      Result := Self._ExecuteNode(BSNode^.Children[i], Depth + 1)
    else
      Result := EBTStatus.Failure;
  end else
    Result := EBTStatus.Failure;
end;

// Executes a single child task in parallel execution
procedure TBTParallelTaskExecutor.Execute();
var
  Status: EBTStatus;
  ParallelNode: ^TBTParallelNode;
begin
  if (Self.Tree = nil) or (Self.NodeHandle.Index < 0) then Exit;

  // Get the correct parallel node based on the handle's NodeType
  if Self.NodeHandle.NodeType = EBTNodeType.ParallelSelector then
    ParallelNode := @Self.Tree^.ParallelSelectorNodes[Self.NodeHandle.Index]
  else if Self.NodeHandle.NodeType = EBTNodeType.ParallelSequence then
    ParallelNode := @Self.Tree^.ParallelSequenceNodes[Self.NodeHandle.Index]
  else
    Exit;

  if (Self.ChildIndex > High(ParallelNode^.Children)) or (ParallelNode^.Children[Self.ChildIndex].Index < 0) then
    Status := EBTStatus.Failure
  else
    Status := Self.Tree^._ExecuteNode(ParallelNode^.Children[Self.ChildIndex], Self.Depth);

  if Assigned(@Self.Tree^.Lock) then
  begin
    Self.Tree^.Lock.Enter();
    try
      ParallelNode^.ParallelResults[Self.ChildIndex] := Status;
      ParallelNode^.ParallelCompleted[Self.ChildIndex] := True;
    finally
      Self.Tree^.Lock.Leave();
    end;
  end else
  begin
    ParallelNode^.ParallelResults[Self.ChildIndex] := Status;
    ParallelNode^.ParallelCompleted[Self.ChildIndex] := True;
  end;
end;

// Handles parallel node execution by managing concurrent child tasks
function TBehaviorTree._HandleParallelNode(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  i, ChildCount, CompletedCount, SuccessCount, FailureCount: Integer;
  ParallelNode: ^TBTParallelNode;
  TaskID: String;
begin
  if Handle.NodeType = EBTNodeType.ParallelSelector then
    ParallelNode := @Self.ParallelSelectorNodes[Handle.Index]
  else
    ParallelNode := @Self.ParallelSequenceNodes[Handle.Index];

  ChildCount := Length(ParallelNode^.Children);

  if ChildCount = 0 then
  begin
    if Handle.NodeType = EBTNodeType.ParallelSelector then
      Exit(EBTStatus.Failure)
    else 
      Exit(EBTStatus.Success);
  end;

  if not ParallelNode^.ParallelTasksSubmitted then
  begin
    SetLength(ParallelNode^.ParallelResults, ChildCount);
    SetLength(ParallelNode^.ParallelCompleted, ChildCount);
    SetLength(ParallelNode^.Executors, ChildCount);
    for i := 0 to ChildCount - 1 do
    begin
      ParallelNode^.ParallelCompleted[i] := False;
      
      ParallelNode^.Executors[i].Tree := @Self;
      ParallelNode^.Executors[i].NodeHandle := Handle;
      ParallelNode^.Executors[i].ChildIndex := i;
      ParallelNode^.Executors[i].Depth := Depth + 1;
      
      TaskID := ParallelNode^.Base.Name + '-child-' + IntToStr(i) + '-' + IntToStr(Time());
      Self.ThreadManager.Submit(TaskID, @ParallelNode^.Executors[i].Execute, 0, True);
    end;
    
    ParallelNode^.ParallelTasksSubmitted := True;
    ParallelNode^.ParallelStartTime := Time();
    Result := EBTStatus.Running;
    Exit;
  end;

  CompletedCount := 0;
  SuccessCount := 0;
  FailureCount := 0;
  
  if Assigned(@Self.Lock) then
  begin
    Self.Lock.Enter();
    try
      for i := 0 to ChildCount - 1 do
      begin
        if ParallelNode^.ParallelCompleted[i] then
        begin
          Inc(CompletedCount);
          case ParallelNode^.ParallelResults[i] of
            EBTStatus.Success: Inc(SuccessCount);
            EBTStatus.Failure: Inc(FailureCount);
          end;
        end;
      end;
    finally
      Self.Lock.Leave();
    end;
  end else
  begin
    for i := 0 to ChildCount - 1 do
    begin
      if ParallelNode^.ParallelCompleted[i] then
      begin
        Inc(CompletedCount);
        case ParallelNode^.ParallelResults[i] of
          EBTStatus.Success: Inc(SuccessCount);
          EBTStatus.Failure: Inc(FailureCount);
        end;
      end;
    end;
  end;

  if (ParallelNode^.ParallelTimeoutMS > 0) and ((Time() - ParallelNode^.ParallelStartTime) >= ParallelNode^.ParallelTimeoutMS) then
  begin
    ParallelNode^.ParallelTasksSubmitted := False;
    Result := EBTStatus.Failure;
    Exit;
  end;

  if (Handle.NodeType = EBTNodeType.ParallelSelector) and (SuccessCount > 0) then
  begin
    ParallelNode^.ParallelTasksSubmitted := False;
    Result := EBTStatus.Success;
    Exit;
  end;

  if (Handle.NodeType = EBTNodeType.ParallelSequence) and (FailureCount > 0) then
  begin
    ParallelNode^.ParallelTasksSubmitted := False;
    Result := EBTStatus.Failure;
    Exit;
  end;

  if CompletedCount < ChildCount then
  begin
    Result := EBTStatus.Running;
    Exit;
  end;
  
  if Handle.NodeType = EBTNodeType.ParallelSelector then
    Result := EBTStatus.Failure
  else
    Result := EBTStatus.Success;

  ParallelNode^.ParallelTasksSubmitted := False;
end; 

(*
### TBehaviorTree.AddChild
```pascal
procedure TBehaviorTree.AddChild(Parent: TBTNodeHandle; Child: TBTNodeHandle);
```
Adds a child to an existing composite node.

Example:
```pascal
MakeSeq := MyTree.CreateSequence('Make Product');
MyTree.AddChild(MakeSeq, MyTree.CreateCondition('Have Materials?', @Self.HasItems));
MyTree.AddChild(MakeSeq, MyTree.CreateAction('Do Make', @Self.DoMake));
```
*)
procedure TBehaviorTree.AddChild(Parent: TBTNodeHandle; Child: TBTNodeHandle);
var
  Children: PBTNodeHandleArray;
begin
  Children := Self._GetNodeChildren(Parent);
  if Children <> nil then
  begin
    SetLength(Children^, Length(Children^) + 1);
    Children^[High(Children^)] := Child;
  end;
end;

(*
### TBehaviorTree.AddChildren
```pascal
procedure TBehaviorTree.AddChildren(Parent: TBTNodeHandle; NewChildren: TBTNodeHandleArray);
```
Adds multiple children to an existing composite node.

Example:
```pascal
MakeSeq := MyTree.CreateSequence('Make Product');
MyTree.AddChildren(MakeSeq, [
  MyTree.CreateCondition('Have Materials?', @Self.HasItems),
  MyTree.CreateAction('Do Make', @Self.DoMake)
]);
```
*)
procedure TBehaviorTree.AddChildren(Parent: TBTNodeHandle; NewChildren: TBTNodeHandleArray);
var
  Children: PBTNodeHandleArray;
  i, StartIndex: Integer;
begin
  Children := Self._GetNodeChildren(Parent);
  if Children <> nil then
  begin
    StartIndex := Length(Children^);
    SetLength(Children^, StartIndex + Length(NewChildren));
    for i := 0 to High(NewChildren) do
      Children^[StartIndex + i] := NewChildren[i];
  end;
end; 

(* DECORATORS *)

(*
## Decorators
Decorator nodes for behavior trees.

Decorators wrap a single child and modify its behavior.
Inverter flips success/failure results.
Retry repeats failed children.
Timer decorators add cooldowns and timeouts.
*)



(*
### TBehaviorTree.CreateInverter
```pascal
function TBehaviorTree.CreateInverter(Name: String; Child: TBTNodeHandle): TBTNodeHandle;
```
Creates an inverter that flips success/failure results.

Example:
```pascal
NotEnemyNearby := MyTree.CreateInverter('Not Enemy Nearby', EnemyCheck);
```
*)
function TBehaviorTree.CreateInverter(Name: String; Child: TBTNodeHandle): TBTNodeHandle;
var
  Node: ^TBTDecoratorNode;
begin
  Node := Self._CreateNode(EBTNodeType.Inverter, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Result.NodeType := EBTNodeType.Inverter;
end;

(*
### TBehaviorTree.CreateForceSuccess
```pascal
function TBehaviorTree.CreateForceSuccess(Name: String; Child: TBTNodeHandle): TBTNodeHandle;
```
Creates a decorator that always returns success.

Example:
```pascal
OptionalAction := MyTree.CreateForceSuccess('Optional', SomeAction);
```
*)
function TBehaviorTree.CreateForceSuccess(Name: String; Child: TBTNodeHandle): TBTNodeHandle;
var
  Node: ^TBTDecoratorNode;
begin
  Node := Self._CreateNode(EBTNodeType.ForceSuccess, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Result.NodeType := EBTNodeType.ForceSuccess;
end;

(*
### TBehaviorTree.CreateForceFailure
```pascal
function TBehaviorTree.CreateForceFailure(Name: String; Child: TBTNodeHandle): TBTNodeHandle;
```
Creates a decorator that always returns failure.

Example:
```pascal
DisabledAction := MyTree.CreateForceFailure('Disabled', SomeAction);
```
*)
function TBehaviorTree.CreateForceFailure(Name: String; Child: TBTNodeHandle): TBTNodeHandle;
var
  Node: ^TBTDecoratorNode;
begin
  Node := Self._CreateNode(EBTNodeType.ForceFailure, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Result.NodeType := EBTNodeType.ForceFailure;
end;

(*
### TBehaviorTree.CreateRetry
```pascal
function TBehaviorTree.CreateRetry(Name: String; Child: TBTNodeHandle; MaxRetries: Integer): TBTNodeHandle;
```
Creates a retry decorator that repeats failed children.

Example:
```pascal
RetryAction := MyTree.CreateRetry('Retry Connect', NetworkAction, 3);
```
*)
function TBehaviorTree.CreateRetry(Name: String; Child: TBTNodeHandle; MaxRetries: Integer): TBTNodeHandle;
var
  Node: ^TBTRetryNode;
begin
  Node := Self._CreateNode(EBTNodeType.Retry, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Node^.MaxRetries := MaxRetries;
  Result.NodeType := EBTNodeType.Retry;
end;

(*
### TBehaviorTree.CreateCooldown
```pascal
function TBehaviorTree.CreateCooldown(Name: String; Child: TBTNodeHandle; CooldownMS: Integer): TBTNodeHandle;
```
Creates a cooldown decorator that limits execution frequency.

Example:
```pascal
CooledAttack := MyTree.CreateCooldown('Cooled Attack', SpecialAttack, 5000);
```
*)
function TBehaviorTree.CreateCooldown(Name: String; Child: TBTNodeHandle; CooldownMS: Integer): TBTNodeHandle;
var
  Node: ^TBTTimerNode;
begin
  Node := Self._CreateNode(EBTNodeType.Cooldown, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Node^.TimerDuration := CooldownMS;
  Result.NodeType := EBTNodeType.Cooldown;
end;

(*
### TBehaviorTree.CreateTimeout
```pascal
function TBehaviorTree.CreateTimeout(Name: String; Child: TBTNodeHandle; TimeoutMS: Integer): TBTNodeHandle;
```
Creates a timeout decorator that limits execution time.

Example:
```pascal
