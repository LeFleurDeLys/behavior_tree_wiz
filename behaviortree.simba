begin
  Node := Self._CreateNode(EBTNodeType.Conditional, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Node^.Condition := @ConditionFunc;
  Result.NodeType := EBTNodeType.Conditional;
end;

(*
### TBehaviorTree.CreateConditional
