(*
### TBehaviorTree.CreateLink
```pascal
function TBehaviorTree.CreateLink(Name: String; Target: TBTNodeHandle): TBTNodeHandle;
```
Creates a link node that jumps to another node.

Example:
```pascal
LinkToCleanup := MyTree.CreateLink('Link to Cleanup', CleanupNode);
```
*)
function TBehaviorTree.CreateLink(Name: String; Target: TBTNodeHandle): TBTNodeHandle;
var
  Node: ^TBTLinkNode;
begin
  Node := Self._CreateNode(EBTNodeType.Link, Result.Index);
  Node^.Base.Name := Name;
  Node^.TargetNode := Target;
  Result.NodeType := EBTNodeType.Link;
end;

// Executes decorator nodes by modifying child results
function TBehaviorTree._ExecuteDecorator(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  DecoratorNode: ^TBTDecoratorNode;
begin
  case Handle.NodeType of
    EBTNodeType.Inverter: DecoratorNode := @Self.InverterNodes[Handle.Index];
    EBTNodeType.ForceSuccess: DecoratorNode := @Self.ForceSuccessNodes[Handle.Index];
    EBTNodeType.ForceFailure: DecoratorNode := @Self.ForceFailureNodes[Handle.Index];
  end;
  case Handle.NodeType of
    EBTNodeType.Inverter:
        case Self._ExecuteNode(DecoratorNode^.Child, Depth + 1) of
          EBTStatus.Success: Result := EBTStatus.Failure;
          EBTStatus.Failure: Result := EBTStatus.Success;
          EBTStatus.Running: Result := EBTStatus.Running;
        end;
    EBTNodeType.ForceSuccess: 
        if Self._ExecuteNode(DecoratorNode^.Child, Depth + 1) = EBTStatus.Running then 
          Result := EBTStatus.Running 
        else 
          Result := EBTStatus.Success;
    EBTNodeType.ForceFailure: 
        if Self._ExecuteNode(DecoratorNode^.Child, Depth + 1) = EBTStatus.Running then 
          Result := EBTStatus.Running 
        else 
          Result := EBTStatus.Failure;
  end;
end;

// Executes retry nodes by repeating child on failure
function TBehaviorTree._ExecuteRetry(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  RetryNode: ^TBTRetryNode;
begin
  RetryNode := @Self.RetryNodes[Handle.Index];
  Result := Self._ExecuteNode(RetryNode^.Child, Depth + 1);
  if Result = EBTStatus.Failure then
  begin
    Inc(RetryNode^.State.RetryCount);
    if RetryNode^.State.RetryCount > RetryNode^.MaxRetries then
      Result := EBTStatus.Failure
    else
      Result := EBTStatus.Running;
  end;
  if Result <> EBTStatus.Running then RetryNode^.State.RetryCount := 0;
end;

// Executes timer nodes (cooldown and timeout) with time-based constraints
function TBehaviorTree._ExecuteTimer(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  TimerNode: ^TBTTimerNode;
begin
  if Handle.NodeType = EBTNodeType.Cooldown then
    TimerNode := @Self.CooldownNodes[Handle.Index]
  else
    TimerNode := @Self.TimeoutNodes[Handle.Index];

  if Handle.NodeType = EBTNodeType.Cooldown then
  begin
    if (TimerNode^.EndTime > 0) and (Time() < TimerNode^.EndTime) then Exit(EBTStatus.Failure);
    Result := Self._ExecuteNode(TimerNode^.Child, Depth + 1);
    if Result <> EBTStatus.Running then
      TimerNode^.EndTime := Time() + TimerNode^.TimerDuration;
  end else // Timeout
  begin
    if TimerNode^.EndTime = 0 then
      TimerNode^.EndTime := Time() + TimerNode^.TimerDuration;
    if Time() >= TimerNode^.EndTime then
    begin
      TimerNode^.EndTime := 0;
      Exit(EBTStatus.Failure);
    end;
    Result := Self._ExecuteNode(TimerNode^.Child, Depth + 1);
    if Result <> EBTStatus.Running then
      TimerNode^.EndTime := 0;
  end;
end;

// Executes repeater nodes by looping child execution
function TBehaviorTree._ExecuteRepeater(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  RepNode: ^TBTRepeaterNode;
begin
  RepNode := @Self.RepeaterNodes[Handle.Index];
  if (RepNode^.RepeatCount > 0) and (RepNode^.State.RepeatCount >= RepNode^.RepeatCount) then
  begin
    RepNode^.State.RepeatCount := 0;
    Exit(EBTStatus.Success);
  end;
  case Self._ExecuteNode(RepNode^.Child, Depth + 1) of
    EBTStatus.Success:
    begin
      Inc(RepNode^.State.RepeatCount);
      if (RepNode^.RepeatCount > 0) and (RepNode^.State.RepeatCount >= RepNode^.RepeatCount) then
      begin
        RepNode^.State.RepeatCount := 0;
        Result := EBTStatus.Success;
      end else
        Result := EBTStatus.Running;
    end;
    EBTStatus.Failure:
    begin
      RepNode^.State.RepeatCount := 0;
      Result := EBTStatus.Failure;
    end;
    EBTStatus.Running: Result := EBTStatus.Running;
  end;
end;

// Executes conditional nodes by checking condition before running child
function TBehaviorTree._ExecuteConditional(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  CondNode: ^TBTConditionalNode;
begin
  CondNode := @Self.ConditionalNodes[Handle.Index];
  if Assigned(@CondNode^.Condition) then
  begin
    if CondNode^.Condition() then Result := Self._ExecuteNode(CondNode^.Child, Depth + 1) else Result := EBTStatus.Failure;
  end else if Assigned(@CondNode^.ConditionMethod) then
  begin
    if CondNode^.ConditionMethod() then Result := Self._ExecuteNode(CondNode^.Child, Depth + 1) else Result := EBTStatus.Failure;
  end else
    Result := EBTStatus.Failure;
end;

// Executes subtree nodes by running separate behavior trees
function TBehaviorTree._ExecuteSubtree(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  SubNode: ^TBTSubtreeNode;
  Subtree: PBehaviorTree;
begin
  SubNode := @Self.SubtreeNodes[Handle.Index];
  if (SubNode^.SubtreeIndex > -1) and (SubNode^.SubtreeIndex <= High(Self.Subtrees)) then
  begin
    Subtree := Self.Subtrees[SubNode^.SubtreeIndex];
    if Subtree^.Root.Index < 0 then
    begin
      Self.SetError(EBTErrorType.NullReference, 'Subtree root node is not set', SubNode^.Base.Name);
      Result := EBTStatus.Failure;
    end
    else
    begin
      // Increment depth counter to prevent circular references
      Inc(Self.CurrentExecutionDepth);
      if Self.CurrentExecutionDepth >= BT_MAX_RECURSION_DEPTH then
      begin
        Self.SetError(EBTErrorType.MaxDepthExceeded, 'Maximum recursion depth exceeded in subtree call', SubNode^.Base.Name);
        Dec(Self.CurrentExecutionDepth);
        Result := EBTStatus.Failure;
      end
      else
      begin
        // Share depth counter with subtree to track total execution depth
        Subtree^.CurrentExecutionDepth := Self.CurrentExecutionDepth;
        Result := Subtree^._ExecuteNode(Subtree^.Root, Depth + 1);
        Self.CurrentExecutionDepth := Subtree^.CurrentExecutionDepth;
        Dec(Self.CurrentExecutionDepth);
      end;
    end;
  end
  else
  begin
    Self.SetError(EBTErrorType.InvalidSubtree, 'Invalid subtree index: ' + IntToStr(SubNode^.SubtreeIndex), SubNode^.Base.Name);
    Result := EBTStatus.Failure;
  end;
end;

// Executes link nodes by jumping to target node
function TBehaviorTree._ExecuteLink(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  LinkNode: ^TBTLinkNode;
begin
  LinkNode := @Self.LinkNodes[Handle.Index];
  Result := Self._ExecuteNode(LinkNode^.TargetNode, Depth + 1);
end; 

(* REACTIVE *)

(*
## Reactive
Reactive nodes for behavior trees.

Reactive nodes monitor blackboard changes and interrupt running children.
Use these for dynamic behavior that needs to respond to changing conditions.
*)



(*
### TBehaviorTree.CreateReactiveSelector
```pascal
function TBehaviorTree.CreateReactiveSelector(Name: String; Children: TBTNodeHandleArray = []): TBTNodeHandle;
```
Creates a reactive selector that interrupts on blackboard changes.
When WatchedKey is provided, only interrupts when that specific blackboard key changes.
When WatchedKey is empty (default), interrupts on any blackboard change.

Example:
```pascal
// Reacts to ALL blackboard changes:
ReactiveSelector := MyTree.CreateReactiveSelector('Reactive Combat', [Health, Combat, Heal]);
// Reacts ONLY to changes on the 'Health' key:
ReactiveSelector := MyTree.CreateReactiveSelector('Reactive Combat', [Health, Combat, Heal], 'Health');
```
*)
function TBehaviorTree.CreateReactiveSelector(Name: String; Children: TBTNodeHandleArray = []; WatchedKey: String = ''): TBTNodeHandle;
var
  Node: ^TBTReactiveNode;
  i: Integer;
begin
  Node := Self._CreateNode(EBTNodeType.ReactiveSelector, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  Node^.RunningChildIndex := -1;
  Node^.LastActivityTimestamp := 0;
  Node^.WatchedKey := WatchedKey;  
  
  SetLength(Node^.ConditionCheckMask, Length(Children));
  SetLength(Node^.LastConditionStates, Length(Children));
  for i := 0 to High(Children) do
  begin
    case Children[i].NodeType of
        EBTNodeType.Condition, EBTNodeType.BlackboardCondition,
        EBTNodeType.Selector, EBTNodeType.Sequence,
        EBTNodeType.ReactiveSelector, EBTNodeType.ReactiveSequence,
        EBTNodeType.EventCondition:
            Node^.ConditionCheckMask[i] := True;
        else
            Node^.ConditionCheckMask[i] := False;
    end;
    Node^.LastConditionStates[i] := EBTStatus.Failure;
  end;
  
  Result.NodeType := EBTNodeType.ReactiveSelector;
end;

(*
### TBehaviorTree.CreateReactiveSequence
```pascal
function TBehaviorTree.CreateReactiveSequence(Name: String; Children: TBTNodeHandleArray = []): TBTNodeHandle;
```
Creates a reactive sequence that interrupts on blackboard changes.
When WatchedKey is provided, only interrupts when that specific blackboard key changes.
When WatchedKey is empty (default), interrupts on any blackboard change.

Example:
```pascal
// Reacts to ALL blackboard changes:
ReactiveSequence := MyTree.CreateReactiveSequence('Reactive Combat', [Check, Approach, Attack]);
// Reacts ONLY to changes on the 'Health' key:
ReactiveSequence := MyTree.CreateReactiveSequence('Reactive Combat', [Check, Approach, Attack], 'Health');
```
*)
function TBehaviorTree.CreateReactiveSequence(Name: String; Children: TBTNodeHandleArray = []; WatchedKey: String = ''): TBTNodeHandle;
var
  Node: ^TBTReactiveNode;
  i: Integer;
begin
  Node := Self._CreateNode(EBTNodeType.ReactiveSequence, Result.Index);
  Node^.Base.Name := Name;
  Node^.Children := Children;
  Node^.RunningChildIndex := -1;
  Node^.LastActivityTimestamp := 0;
  Node^.WatchedKey := WatchedKey;  
  
  SetLength(Node^.ConditionCheckMask, Length(Children));
  SetLength(Node^.LastConditionStates, Length(Children));
  for i := 0 to High(Children) do
  begin
    case Children[i].NodeType of
        EBTNodeType.Condition, EBTNodeType.BlackboardCondition,
        EBTNodeType.Selector, EBTNodeType.Sequence,
        EBTNodeType.ReactiveSelector, EBTNodeType.ReactiveSequence,
        EBTNodeType.EventCondition:
            Node^.ConditionCheckMask[i] := True;
        else
            Node^.ConditionCheckMask[i] := False;
    end;
    Node^.LastConditionStates[i] := EBTStatus.Success;  
  end;
  
  Result.NodeType := EBTNodeType.ReactiveSequence;
end;

(*
### TBehaviorTree.CreateDataGatherer
```pascal
function TBehaviorTree.CreateDataGatherer(Name: String; BlackboardKey: String; GatherFunc: TBTAction; UpdateIntervalMS: Integer = 1000): TBTNodeHandle;
```
Creates a data gatherer that continuously updates blackboard.

Example:
```pascal
Gatherer := MyTree.CreateDataGatherer('Enemy Distance', 'EnemyDistance', @GetEnemyDistance, 500);
```
*)
function TBehaviorTree.CreateDataGatherer(Name: String; BlackboardKey: String; GatherFunc: TBTAction; UpdateIntervalMS: Integer = 1000): TBTNodeHandle;
var
  Node: ^TBTDataGathererNode;
begin
  Node := Self._CreateNode(EBTNodeType.DataGatherer, Result.Index);
  Node^.Base.Name := Name;
  Node^.BlackboardKey := BlackboardKey;
  Node^.GatherFunction := @GatherFunc;
  Node^.UpdateInterval := UpdateIntervalMS;
  Node^.LastUpdateTime := 0;
  Node^.ContinuousUpdate := True;
  
  Result.NodeType := EBTNodeType.DataGatherer;
end;

(*
### TBehaviorTree.CreateDataGatherer
```pascal
function TBehaviorTree.CreateDataGatherer(Name: String; BlackboardKey: String; GatherMethod: TBTActionMethod; UpdateIntervalMS: Integer = 1000): TBTNodeHandle;
```
Creates a data gatherer using a method.

Example:
```pascal
Gatherer := MyTree.CreateDataGatherer('Health', 'PlayerHealth', @Self.GetPlayerHealth, 250);
```
*)
function TBehaviorTree.CreateDataGatherer(Name: String; BlackboardKey: String; GatherMethod: TBTActionMethod; UpdateIntervalMS: Integer = 1000): TBTNodeHandle; overload;
var
  Node: ^TBTDataGathererNode;
begin
  Node := Self._CreateNode(EBTNodeType.DataGatherer, Result.Index);
  Node^.Base.Name := Name;
  Node^.BlackboardKey := BlackboardKey;
  Node^.GatherMethod := @GatherMethod;
  Node^.UpdateInterval := UpdateIntervalMS;
  Node^.LastUpdateTime := 0;
  Node^.ContinuousUpdate := True;
  
  Result.NodeType := EBTNodeType.DataGatherer;
end;

// Executes reactive composite nodes with blackboard change interruption
function TBehaviorTree._ExecuteReactiveComposite(Handle: TBTNodeHandle; Depth: Integer): EBTStatus;
var
  ReactiveNode: ^TBTReactiveNode;
  i, StartIndex: Integer;
  ChildStatus: EBTStatus;
  ActivityChanges: array of TBlackboardChange;
  MustRestart: Boolean;
  RelevantChanges: Integer;
  LastTimestamp, CurrentTime: Double;  
begin
  if Handle.NodeType = EBTNodeType.ReactiveSelector then
    ReactiveNode := @Self.ReactiveSelectorNodes[Handle.Index]
  else
    ReactiveNode := @Self.ReactiveSequenceNodes[Handle.Index];

  if Length(ReactiveNode^.Children) = 0 then
  begin
    if Handle.NodeType = EBTNodeType.ReactiveSelector then Exit(EBTStatus.Failure) else Exit(EBTStatus.Success);
  end;

  LastTimestamp := ReactiveNode^.LastActivityTimestamp;
  CurrentTime := PerformanceTime();
  
  ActivityChanges := Self.Blackboard.GetActivitySince(LastTimestamp);
  RelevantChanges := 0;
  for i := 0 to High(ActivityChanges) do
  begin
    if ActivityChanges[i].ChangeType <> EBBChangeType.Read then
    begin
      if (ReactiveNode^.WatchedKey = '') or (ActivityChanges[i].Key = ReactiveNode^.WatchedKey) then
        Inc(RelevantChanges);
    end;
  end;

  if Self.DebugLevel >= EBTDebugLevel.Verbose then
    WriteLn(Format('[REACTIVE] %s: WatchedKey=%s, LastTimestamp=%.6f, CurrentTime=%.6f, Found %d total activities, %d relevant changes, RunningChildIndex=%d', 
      [ReactiveNode^.Base.Name, ReactiveNode^.WatchedKey, LastTimestamp, CurrentTime, Length(ActivityChanges), RelevantChanges, ReactiveNode^.RunningChildIndex]));

  MustRestart := (ReactiveNode^.RunningChildIndex > -1) and (RelevantChanges > 0);
  if MustRestart then
  begin
    if Self.DebugLevel >= EBTDebugLevel.Verbose then
      WriteLn(Format('[REACTIVE] %s: Interrupting running child %d due to blackboard changes', 
        [ReactiveNode^.Base.Name, ReactiveNode^.RunningChildIndex]));
    ReactiveNode^.RunningChildIndex := -1;
  end;

  // Update timestamp after checking activities but before executing children
  ReactiveNode^.LastActivityTimestamp := CurrentTime;

  // If we weren't interrupted, resume from the running child. Otherwise, start at 0.
  StartIndex := 0;
  if ReactiveNode^.RunningChildIndex > -1 then
    StartIndex := ReactiveNode^.RunningChildIndex;
    
  if Handle.NodeType = EBTNodeType.ReactiveSelector then
  begin
    for i := StartIndex to High(ReactiveNode^.Children) do
    begin
      ChildStatus := Self._ExecuteNode(ReactiveNode^.Children[i], Depth + 1);
      if ChildStatus <> EBTStatus.Failure then
      begin
        if ChildStatus = EBTStatus.Running then ReactiveNode^.RunningChildIndex := i else ReactiveNode^.RunningChildIndex := -1;
        Exit(ChildStatus);
      end;
    end;
    ReactiveNode^.RunningChildIndex := -1;
    Result := EBTStatus.Failure;
  end
  else // ReactiveSequence
  begin
    for i := StartIndex to High(ReactiveNode^.Children) do
    begin
      ChildStatus := Self._ExecuteNode(ReactiveNode^.Children[i], Depth + 1);
      if ChildStatus <> EBTStatus.Success then
      begin
        if ChildStatus = EBTStatus.Running then ReactiveNode^.RunningChildIndex := i else ReactiveNode^.RunningChildIndex := -1;
        Exit(ChildStatus);
      end;
    end;
    ReactiveNode^.RunningChildIndex := -1;
    Result := EBTStatus.Success;
  end;
end;

// Executes data gatherer nodes with timed updates
function TBehaviorTree._ExecuteDataGatherer(Handle: TBTNodeHandle): EBTStatus;
var
  DataNode: ^TBTDataGathererNode;
  CurrentTime: Double;  
  GatherResult: EBTStatus;
  OldValue, NewValue: Variant;
  ShouldUpdate: Boolean;
begin
  DataNode := @Self.DataGathererNodes[Handle.Index];
  CurrentTime := PerformanceTime();
  
  // Check if we should update based on time since last actual update
  if DataNode^.LastUpdateTime = 0 then
    ShouldUpdate := True  // First execution - always update
  else
    ShouldUpdate := (CurrentTime - DataNode^.LastUpdateTime) >= (DataNode^.UpdateInterval / 1000.0);
  
  if ShouldUpdate then
  begin
    OldValue := Self.Blackboard.Get(DataNode^.BlackboardKey);
    if Assigned(@DataNode^.GatherFunction) then
      GatherResult := DataNode^.GatherFunction()
    else if Assigned(@DataNode^.GatherMethod) then
      GatherResult := DataNode^.GatherMethod()
    else
    begin
      Self.SetError(EBTErrorType.InvalidNode, 'Data gatherer has no assigned function', DataNode^.Base.Name);
      Exit(EBTStatus.Failure);
    end;
    if GatherResult = EBTStatus.Failure then
    begin
      if Self.DebugLevel >= EBTDebugLevel.Verbose then
        WriteLn(Format('[DATA] Failed to gather data for "%s"', [DataNode^.BlackboardKey]));
      Exit(EBTStatus.Failure);
    end;
    
    // Update timestamp AFTER successful gather function call
    DataNode^.LastUpdateTime := CurrentTime;
    
    NewValue := Self.Blackboard.Get(DataNode^.BlackboardKey);
    if Self.DebugLevel >= EBTDebugLevel.Verbose then
    begin
      if OldValue <> NewValue then
        WriteLn(Format('[DATA] Updated "%s": %s -> %s', [DataNode^.BlackboardKey, ToStr(OldValue), ToStr(NewValue)]))
      else
        WriteLn(Format('[DATA] Refreshed "%s": %s', [DataNode^.BlackboardKey, ToStr(NewValue)]));
    end;
  end;
  if DataNode^.ContinuousUpdate then
    Result := EBTStatus.Running
  else
    Result := EBTStatus.Success;
end; 

(* UTILITIES *)

(*
## Utilities
Utility nodes for behavior trees.

Repeat loops, delays, static results, and probability-based decisions.
*)



(*
### TBehaviorTree.CreateRepeatUntilSuccess
```pascal
function TBehaviorTree.CreateRepeatUntilSuccess(Name: String; Child: TBTNodeHandle; MaxTries: Integer = -1): TBTNodeHandle;
```
Repeats a child until it succeeds. MaxTries limits the number of attempts (-1 = unlimited).

Examples:
```pascal
// Retry opening a door up to 3 times
RetryAction := MyTree.CreateRepeatUntilSuccess('Retry Open Door', OpenDoorAction, 3);

// Retry indefinitely until success
RetryAction := MyTree.CreateRepeatUntilSuccess('Retry Open Door', OpenDoorAction);

// Fail immediately (useful for testing)
RetryAction := MyTree.CreateRepeatUntilSuccess('Retry Open Door', OpenDoorAction, 0);
```
*)
function TBehaviorTree.CreateRepeatUntilSuccess(Name: String; Child: TBTNodeHandle; MaxTries: Integer = -1): TBTNodeHandle;
var
  Node: ^TBTRepeatUntilNode;
begin
  // Validate MaxTries parameter
  if MaxTries < -1 then
    MaxTries := -1;
  
  Node := Self._CreateNode(EBTNodeType.RepeatUntilSuccess, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Node^.RepeatUntilSuccess := True;
  Node^.MaxTries := MaxTries;
  Node^.CurrentTries := 0;
  Result.NodeType := EBTNodeType.RepeatUntilSuccess;
end;

(*
### TBehaviorTree.CreateRepeatUntilFailure
```pascal
function TBehaviorTree.CreateRepeatUntilFailure(Name: String; Child: TBTNodeHandle; MaxTries: Integer = -1): TBTNodeHandle;
```
Repeats a child until it fails. MaxTries limits the number of attempts (-1 = unlimited).

Examples:
```pascal
// Patrol until interrupted (up to 10 times)
ContinuousPatrol := MyTree.CreateRepeatUntilFailure('Continuous Patrol', PatrolAction, 10);

// Patrol indefinitely until failure
ContinuousPatrol := MyTree.CreateRepeatUntilFailure('Continuous Patrol', PatrolAction);

// Stop immediately (useful for testing)
ContinuousPatrol := MyTree.CreateRepeatUntilFailure('Continuous Patrol', PatrolAction, 0);
```
*)
function TBehaviorTree.CreateRepeatUntilFailure(Name: String; Child: TBTNodeHandle; MaxTries: Integer = -1): TBTNodeHandle;
var
  Node: ^TBTRepeatUntilNode;
begin
  // Validate MaxTries parameter
  if MaxTries < -1 then
    MaxTries := -1;
  
  Node := Self._CreateNode(EBTNodeType.RepeatUntilFailure, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Node^.RepeatUntilSuccess := False;
  Node^.MaxTries := MaxTries;
  Node^.CurrentTries := 0;
  Result.NodeType := EBTNodeType.RepeatUntilFailure;
end;

