function TBehaviorTree.HasErrors(): Boolean;
begin
  Result := Self.LastError.ErrorType <> EBTErrorType.None;
end;

// Internal execution tracing
procedure TBehaviorTree._AddTraceEntry(NodePath: String; NodeName: String; Status: EBTStatus; ExecutionTime: Double; Depth: Integer);
begin
  if Self.DebugLevel <> EBTDebugLevel.Verbose then Exit;
  if Length(Self.ExecutionTrace) >= Self.MaxTraceSize then
  begin
    Move(Self.ExecutionTrace[1], Self.ExecutionTrace[0], (Length(Self.ExecutionTrace) - 1) * SizeOf(TBTExecutionTrace));
    Self.ExecutionTrace[High(Self.ExecutionTrace)].NodePath := NodePath;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].NodeName := NodeName;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].Status := Status;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].ExecutionTime := ExecutionTime;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].Depth := Depth;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].Timestamp := Time();
  end else
  begin
    SetLength(Self.ExecutionTrace, Length(Self.ExecutionTrace) + 1);
    Self.ExecutionTrace[High(Self.ExecutionTrace)].NodePath := NodePath;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].NodeName := NodeName;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].Status := Status;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].ExecutionTime := ExecutionTime;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].Depth := Depth;
    Self.ExecutionTrace[High(Self.ExecutionTrace)].Timestamp := Time();
  end;
end;

