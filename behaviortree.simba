// Internal node structure printing
procedure TBehaviorTree._PrintNode(Handle: TBTNodeHandle; Depth: Integer);
var
  i: Integer;
  TypeStr, Name: String;
  NodeBase: ^TBTNodeBase;
  Children: PBTNodeHandleArray;
  SingleChild: TBTNodeHandle;
begin
  NodeBase := Self._GetNodeBase(Handle);
  if NodeBase = nil then Exit;

  Name := NodeBase^.Name;
  TypeStr := ToStr(Handle.NodeType).After('EBTNodeType.').ToUpper();

  if Handle.NodeType = EBTNodeType.Subtree then
  begin
    // Special handling for Subtree to print its name
  end
  else
  begin
    Self.Lock.Enter();
    try
      WriteLn(Format('%s%s "%s"', [''.PadLeft(Depth * 2), TypeStr, Name]));
    finally
      Self.Lock.Leave();
    end;
  end;

  Children := Self._GetNodeChildren(Handle);
  if Children <> nil then
    for i := 0 to High(Children^) do
      Self._PrintNode(Children^[i], Depth + 1);

  SingleChild := Self._GetNodeChild(Handle);
  if SingleChild.Index >= 0 then
    Self._PrintNode(SingleChild, Depth + 1);
end;

(*
### PrintStructure
```pascal
procedure TBehaviorTree.PrintStructure();
```
Prints the tree structure for debugging.

Example:
```pascal
Tree.PrintStructure();
```
*)
procedure TBehaviorTree.PrintStructure();
begin
  Self.Lock.Enter();
  try
    WriteLn(Format('--- Tree Structure: %s ---', [Self.Name]));
    if Self.Root.Index >= 0 then
      Self._PrintNode(Self.Root, 0);
    WriteLn(''.PadLeft(30, '-'));
  finally
    Self.Lock.Leave();
  end;
end;

(*
### ValidateTree
```pascal
procedure TBehaviorTree.ValidateTree();
```
Validates the tree structure for issues.

Example:
```pascal
Tree.ValidateTree();
```
*)
procedure TBehaviorTree.ValidateTree();
var
  VisitedSubtrees: array of Integer;

  procedure ValidateHandle(Handle: TBTNodeHandle; NodeName: String);
  begin
    if Handle.Index < 0 then
      raise Format('[BT ERROR] Invalid handle in "%s": Index < 0', [NodeName]);
    
    case Handle.NodeType of
      EBTNodeType.Action: if Handle.Index >= Length(Self.ActionNodes) then raise Format('[BT ERROR] Invalid Action handle in "%s"', [NodeName]);
      EBTNodeType.Selector: if Handle.Index >= Length(Self.SelectorNodes) then raise Format('[BT ERROR] Invalid Selector handle in "%s"', [NodeName]);
      EBTNodeType.Sequence: if Handle.Index >= Length(Self.SequenceNodes) then raise Format('[BT ERROR] Invalid Sequence handle in "%s"', [NodeName]);
      EBTNodeType.Subtree: if Handle.Index >= Length(Self.SubtreeNodes) then raise Format('[BT ERROR] Invalid Subtree handle in "%s"', [NodeName]);
    end;
  end;

  procedure ValidateSubtreeCircular(SubtreeIndex: Integer);
  var
    i: Integer;
  begin
    for i := 0 to High(VisitedSubtrees) do
      if VisitedSubtrees[i] = SubtreeIndex then
        raise Format('[BT ERROR] Circular reference detected in subtree %d', [SubtreeIndex]);
    
    SetLength(VisitedSubtrees, Length(VisitedSubtrees) + 1);
    VisitedSubtrees[High(VisitedSubtrees)] := SubtreeIndex;
  end;

  procedure ValidateComposite(Handle: TBTNodeHandle);
  var
    Children: PBTNodeHandleArray;
  begin
    Children := Self._GetNodeChildren(Handle);
    if (Children <> nil) and (Length(Children^) = 0) then
      raise Format('[BT ERROR] Empty composite "%s" has no children', [Self._GetNodeName(Handle)]);
  end;

var
  i: Integer;
  Handle: TBTNodeHandle;
begin
  SetLength(VisitedSubtrees, 0);
  
  if Self.Root.Index < 0 then
    raise '[BT ERROR] No root node set';
  
  ValidateHandle(Self.Root, 'Root');
  
  for i := 0 to High(Self.SubtreeNodes) do
  begin
    if (Self.SubtreeNodes[i].SubtreeIndex >= 0) and (Self.SubtreeNodes[i].SubtreeIndex < Length(Self.Subtrees)) then
      ValidateSubtreeCircular(Self.SubtreeNodes[i].SubtreeIndex)
    else if Self.SubtreeNodes[i].SubtreeIndex >= Length(Self.Subtrees) then
      raise Format('[BT ERROR] Subtree index %d out of bounds', [Self.SubtreeNodes[i].SubtreeIndex]);
  end;
  
  for i := 0 to High(Self.SelectorNodes) do
  begin
    Handle.Index := i;
    Handle.NodeType := EBTNodeType.Selector;
    ValidateComposite(Handle);
  end;
  
  for i := 0 to High(Self.SequenceNodes) do
  begin
    Handle.Index := i;
    Handle.NodeType := EBTNodeType.Sequence;
    ValidateComposite(Handle);
  end;
end;

(*
### TBehaviorTree.GenerateProfileReport
```pascal
function TBehaviorTree.GenerateProfileReport(): array of TBTNodeProfile;
```
Generates a performance report for all nodes (requires verbose debug level).

Example:
```pascal
Tree.SetDebugLevel(EBTDebugLevel.Verbose);
Tree.Tick();
Report := Tree.GenerateProfileReport();
```
*)
function TBehaviorTree.GenerateProfileReport(): array of TBTNodeProfile;
type
  PBTNodeProfile = ^TBTNodeProfile;
var
  i, j: Integer;
  Trace: TBTExecutionTrace;
  Profile: PBTNodeProfile;
  Found: Boolean;
begin
  if Length(Self.ExecutionTrace) = 0 then
  begin
    if Self.DebugLevel <> EBTDebugLevel.Verbose then
      WriteLn('[BT PROFILE] Profiling is disabled. Use SetDebugLevel(EBTDebugLevel.Verbose) to enable.')
    else
      WriteLn('[BT PROFILE] No execution trace available to generate a report.');
    Exit([]);
  end;
  SetLength(Result, 0);
  for i := 0 to High(Self.ExecutionTrace) do
  begin
    Trace := Self.ExecutionTrace[i];
    Found := False;
    for j := 0 to High(Result) do
    begin
      if Result[j].NodeName = Trace.NodeName then
      begin
        Profile := @Result[j];
        Found := True;
        Break;
      end;
    end;
    if not Found then
    begin
      SetLength(Result, Length(Result) + 1);
      Profile := @Result[High(Result)];
      Profile^.NodeName := Trace.NodeName;
      Profile^.MinTimeMS := -1;
    end;
    Inc(Profile^.ExecutionCount);
    Profile^.TotalTimeMS := Profile^.TotalTimeMS + Trace.ExecutionTime;
    if (Profile^.MinTimeMS = -1) or (Trace.ExecutionTime < Profile^.MinTimeMS) then
      Profile^.MinTimeMS := Trace.ExecutionTime;
    if Trace.ExecutionTime > Profile^.MaxTimeMS then
      Profile^.MaxTimeMS := Trace.ExecutionTime;
    case Trace.Status of
      EBTStatus.Success: Inc(Profile^.SuccessCount);
      EBTStatus.Failure: Inc(Profile^.FailureCount);
      EBTStatus.Running: Inc(Profile^.RunningCount);
    end;
  end;
  for i := 0 to High(Result) do
    if Result[i].ExecutionCount > 0 then
      Result[i].AvgTimeMS := Result[i].TotalTimeMS / Result[i].ExecutionCount;
end;

(*
### TBehaviorTree.PrintProfileReport
```pascal
procedure TBehaviorTree.PrintProfileReport();
```
Prints a formatted performance report to console.

Example:
```pascal
Tree.SetDebugLevel(EBTDebugLevel.Verbose);
Tree.Tick();
Tree.PrintProfileReport();
```
*)
procedure TBehaviorTree.PrintProfileReport();
var
  Report: array of TBTNodeProfile;
  i: Integer;
  Profile: TBTNodeProfile;
begin
  Report := Self.GenerateProfileReport();
  if Length(Report) = 0 then
    Exit;
  WriteLn('--- Behavior Tree Profile Report ---');
  WriteLn(Format('%-25s | %-5s | %-5s | %-5s | %-5s | %-10s | %-10s | %-10s',
    ['Node Name', 'Count', 'OK', 'Fail', 'Run', 'Avg (ms)', 'Min (ms)', 'Max (ms)']));
  WriteLn(''.PadLeft(95, '-'));
  for i := 0 to High(Report) do
  begin
    Profile := Report[i];
    WriteLn(Format('%-25s | %-5d | %-5d | %-5d | %-5d | %-10.4f | %-10.4f | %-10.4f',
      [Profile.NodeName, Profile.ExecutionCount, Profile.SuccessCount, Profile.FailureCount,
      Profile.RunningCount, Profile.AvgTimeMS, Profile.MinTimeMS, Profile.MaxTimeMS]));
  end;
  WriteLn(''.PadLeft(95, '-'));
end; 
