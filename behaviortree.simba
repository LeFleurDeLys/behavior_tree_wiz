    EBTNodeType.DataGatherer: if Handle.Index < Length(Self.DataGathererNodes) then Result := @Self.DataGathererNodes[Handle.Index].State;
    EBTNodeType.RepeatUntilSuccess: if Handle.Index < Length(Self.RepeatUntilNodes) then Result := @Self.RepeatUntilNodes[Handle.Index].State;
    EBTNodeType.RepeatUntilFailure: if Handle.Index < Length(Self.RepeatUntilNodes) then Result := @Self.RepeatUntilNodes[Handle.Index].State;
    EBTNodeType.Delay: if Handle.Index < Length(Self.DelayNodes) then Result := @Self.DelayNodes[Handle.Index].State;
    EBTNodeType.Success: if Handle.Index < Length(Self.StaticConditionNodes) then Result := @Self.StaticConditionNodes[Handle.Index].State;
    EBTNodeType.Failure: if Handle.Index < Length(Self.StaticConditionNodes) then Result := @Self.StaticConditionNodes[Handle.Index].State;
