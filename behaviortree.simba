function TBehaviorTree.CreateTimeout(Name: String; Child: TBTNodeHandle; TimeoutMS: Integer): TBTNodeHandle;
var
  Node: ^TBTTimerNode;
begin
  Node := Self._CreateNode(EBTNodeType.Timeout, Result.Index);
  Node^.Base.Name := Name;
  Node^.Child := Child;
  Node^.TimerDuration := TimeoutMS;
  Result.NodeType := EBTNodeType.Timeout;
