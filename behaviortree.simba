(* BLACKBOARD *)

(*
## Blackboard
Shared data storage for behavior trees.

Thread-safe key-value store that all nodes can read from and write to.
Supports any data type and provides comparison operations for conditions.
*)


type
  (*
  ### EBBOperator
  Comparison operators for blackboard conditions.
  
  ```pascal
  HealthCheck := Tree.CreateBlackboardCondition('Health Check', 'Health', EBBOperator.GreaterThan, 50);
  ```
  *)
  EBBOperator = (Equal, NotEqual, GreaterThan, LessThan, GreaterThanOrEqual, LessThanOrEqual);
  
  EBBChangeType = (Create, Update, Delete, Read);

  TBlackboardChange = record
    Key: String;
    OldValue: Variant;
    NewValue: Variant;
    ChangeType: EBBChangeType;
    Timestamp: Double;
  end;

  TStringIntern = record
    StringToID: TStringMap<Integer>;
    IDToString: TStringArray;
    NextID: Integer;
    TotalOps: Integer;
    CacheHits: Integer;
    HashCache: array of record
      Hash: UInt32;
      ID: Integer;
      Valid: Boolean;
    end;
  end;

  TBlackboard = record
    Values: array of Variant;
    ValidSlots: array of Boolean;
    StringIntern: TStringIntern;
    EnableTracing: Boolean;
    WatchedKeys: TStringArray;
    Lock: TLock;
    ActivityStream: array of TBlackboardChange;
    MaxActivitySize: Integer;
    ActivityEnabled: Boolean;
  end;

// Optimized key lookup using string interning and hash caching
function TBlackboard._InternKey(Key: String): Integer;
var
  Hash: UInt32;
  i: Integer;
begin
  Inc(Self.StringIntern.TotalOps);
  Hash := Key.Hash();
  
  for i := 0 to High(Self.StringIntern.HashCache) do
  begin
    if Self.StringIntern.HashCache[i].Valid and 
       (Self.StringIntern.HashCache[i].Hash = Hash) then
    begin
      Inc(Self.StringIntern.CacheHits);
      Result := Self.StringIntern.HashCache[i].ID;
      Exit;
    end;
  end;
  
  // Cache miss - check string map
  if Self.StringIntern.StringToID.Exists(Key) then
  begin
    Result := Self.StringIntern.StringToID.Value[Key];
    Self._AddToHashCache(Hash, Result);
  end
  else
  begin
    // New string - assign next available ID
    Result := Self.StringIntern.NextID;
    Inc(Self.StringIntern.NextID);
    Self.StringIntern.StringToID.Value[Key] := Result;
    SetLength(Self.StringIntern.IDToString, Length(Self.StringIntern.IDToString) + 1);
    Self.StringIntern.IDToString[High(Self.StringIntern.IDToString)] := Key;
    Self._AddToHashCache(Hash, Result);
  end;
end;

// Adds entries to the hash cache for performance optimization
procedure TBlackboard._AddToHashCache(Hash: UInt32; ID: Integer);
var
  i: Integer;
begin
  // Look for empty slot first
  for i := 0 to High(Self.StringIntern.HashCache) do
  begin
    if not Self.StringIntern.HashCache[i].Valid then
    begin
      Self.StringIntern.HashCache[i].Hash := Hash;
      Self.StringIntern.HashCache[i].ID := ID;
      Self.StringIntern.HashCache[i].Valid := True;
      Exit;
    end;
  end;
  
  // No empty slot - expand cache
  SetLength(Self.StringIntern.HashCache, Length(Self.StringIntern.HashCache) + 1);
  i := High(Self.StringIntern.HashCache);
  Self.StringIntern.HashCache[i].Hash := Hash;
  Self.StringIntern.HashCache[i].ID := ID;
  Self.StringIntern.HashCache[i].Valid := True;
end;

(*
### TBlackboard.Setup
```pascal
procedure TBlackboard.Setup();
```
Initializes the blackboard. Must be called before use.

Example:
```pascal
Blackboard.Setup();
```
*)
procedure TBlackboard.Setup();
begin
  Self.Lock := TLock.Create();
  Self.MaxActivitySize := 1000;
  Self.ActivityEnabled := True;
  Self.StringIntern.NextID := 0;
  SetLength(Self.StringIntern.IDToString, 0);
  SetLength(Self.StringIntern.HashCache, 0);
  SetLength(Self.Values, 0);
  SetLength(Self.ValidSlots, 0);
  Self.StringIntern.TotalOps := 0;
  Self.StringIntern.CacheHits := 0;
end;

(*
### TBlackboard.Free
```pascal
procedure TBlackboard.Free();
```
Cleans up blackboard resources.

Example:
```pascal
Blackboard.Free();
```
*)
procedure TBlackboard.Free();
begin
  if Assigned(@Self.Lock) then
    Self.Lock.Free();
end;

(*
### TBlackboard.Get
```pascal
function TBlackboard.Get(Key: String; Default: Variant = nil): Variant;
```
Gets a value from the blackboard.

Example:
```pascal
Health := Blackboard.Get('Health', 100); // Default to 100 if not found
```
*)
function TBlackboard.Get(Key: String; Default: Variant = nil): Variant;
var
  KeyID: Integer;
  Change: TBlackboardChange;
begin
  Self.Lock.Enter();
  try
    KeyID := Self._InternKey(Key);
    
    if (KeyID < Length(Self.Values)) and Self.ValidSlots[KeyID] then
    begin
      Result := Self.Values[KeyID];
      
      if Self.ActivityEnabled then
      begin
        Change.Key := Key;
        Change.OldValue := nil;
        Change.NewValue := Result;
        Change.ChangeType := EBBChangeType.Read;
        Change.Timestamp := PerformanceTime();
        Self._AddToActivityStream(Change);
      end;
    end
    else
      Result := Default;
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.Put
```pascal
procedure TBlackboard.Put(Key: String; Value: Variant);
```
Stores a value in the blackboard.

Example:
```pascal
Blackboard.Put('Health', 85);
Blackboard.Put('Position', TPoint.Create(100, 200));
```
*)
procedure TBlackboard.Put(Key: String; Value: Variant);
var
  KeyID: Integer;
  OldValue: Variant;
  IsNew: Boolean;
  Change: TBlackboardChange;
begin
  Self.Lock.Enter();
  try
    KeyID := Self._InternKey(Key);
    
    if KeyID >= Length(Self.Values) then
    begin
      SetLength(Self.Values, KeyID + 1);
      SetLength(Self.ValidSlots, KeyID + 1);
    end;
    
    IsNew := not Self.ValidSlots[KeyID];
    if not IsNew then
      OldValue := Self.Values[KeyID];

    // Only update if new or value actually changed
    if (not IsNew) and (OldValue = Value) then
      Exit;

    Self.Values[KeyID] := Value;
    Self.ValidSlots[KeyID] := True;

    if Self.ActivityEnabled then
    begin
      Change.Key := Key;
      Change.OldValue := OldValue;
      Change.NewValue := Value;
      if IsNew then
        Change.ChangeType := EBBChangeType.Create
      else
        Change.ChangeType := EBBChangeType.Update;
      Change.Timestamp := PerformanceTime();
      Self._AddToActivityStream(Change);
    end;

    if Self.EnableTracing then
    begin
      if IsNew then
        WriteLn(Format('[BLACKBOARD] Created "%s" = %s', [Key, ToStr(Value)]))
      else
        WriteLn(Format('[BLACKBOARD] Updated "%s" = %s', [Key, ToStr(Value)]));
    end;

    if Self._IsKeyWatched(Key) then
    begin
      if IsNew then
        WriteLn(Format('[BLACKBOARD WATCH] Key "%s" created: %s', [Key, ToStr(Value)]))
      else
        WriteLn(Format('[BLACKBOARD WATCH] Key "%s" changed: %s -> %s', [Key, ToStr(OldValue), ToStr(Value)]));
    end;
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.HasKey
```pascal
function TBlackboard.HasKey(Key: String): Boolean;
```
Checks if a key exists.

Example:
```pascal
if Blackboard.HasKey('Health') then
  WriteLn('Health is tracked');
```
*)
function TBlackboard.HasKey(Key: String): Boolean;
var
  KeyID: Integer;
begin
  Self.Lock.Enter();
  try
    KeyID := Self._InternKey(Key);
    Result := (KeyID < Length(Self.Values)) and Self.ValidSlots[KeyID];
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.RemoveKey
```pascal
function TBlackboard.RemoveKey(Key: String): Boolean;
```
Removes a key and its value.

Example:
```pascal
Blackboard.RemoveKey('TempData');
```
*)
function TBlackboard.RemoveKey(Key: String): Boolean;
var
  KeyID: Integer;
  OldValue: Variant;
  Change: TBlackboardChange;
begin
  Self.Lock.Enter();
  try
    KeyID := Self._InternKey(Key);
    Result := (KeyID < Length(Self.Values)) and Self.ValidSlots[KeyID];
    if Result then
    begin
      OldValue := Self.Values[KeyID];
      Self.ValidSlots[KeyID] := False;
      
      if Self.ActivityEnabled then
      begin
        Change.Key := Key;
        Change.OldValue := OldValue;
        Change.NewValue := nil;
        Change.ChangeType := EBBChangeType.Delete;
        Change.Timestamp := PerformanceTime();
        Self._AddToActivityStream(Change);
      end;
      
      if Self.EnableTracing then
        WriteLn(Format('[BLACKBOARD] Deleted "%s" (was: %s)', [Key, ToStr(OldValue)]));
    end;
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.GetKeys
```pascal
function TBlackboard.GetKeys(): TStringArray;
```
Gets all keys currently stored.

Example:
```pascal
Keys := Blackboard.GetKeys();
```
*)
function TBlackboard.GetKeys(): TStringArray;
var
  i, Count: Integer;
begin
  Self.Lock.Enter();
  try
    SetLength(Result, 0);
    for i := 0 to High(Self.ValidSlots) do
      if Self.ValidSlots[i] then
      begin
        Count := Length(Result);
        SetLength(Result, Count + 1);
        Result[Count] := Self.StringIntern.IDToString[i];
      end;
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.Count
```pascal
function TBlackboard.Count(): Integer;
```
Returns the number of keys stored.

Example:
```pascal
WriteLn(Format('Blackboard has %d entries', [Blackboard.Count()]));
```
*)
function TBlackboard.Count(): Integer;
var
  i: Integer;
begin
  Result := 0;
  for i := 0 to High(Self.ValidSlots) do
    if Self.ValidSlots[i] then
      Inc(Result);
end;

(*
### TBlackboard.Clear
```pascal
procedure TBlackboard.Clear();
```
Removes all keys and values.

Example:
```pascal
Blackboard.Clear();
```
*)
procedure TBlackboard.Clear();
begin
  Self.Lock.Enter();
  try
    SetLength(Self.Values, 0);
    SetLength(Self.ValidSlots, 0);
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.Compare
```pascal
function TBlackboard.Compare(Key: String; Op: EBBOperator; CompareWith: Variant): Boolean;
```
Compares a blackboard value with another value.

Example:
```pascal
if Blackboard.Compare('Health', EBBOperator.GreaterThan, 50) then
  WriteLn('Health is good');
```
*)
function TBlackboard.Compare(Key: String; Op: EBBOperator; CompareWith: Variant): Boolean;
var
  KeyID: Integer;
  Value: Variant;
begin
  Result := False;
  Self.Lock.Enter();
  try
    KeyID := Self._InternKey(Key);
    if (KeyID >= Length(Self.Values)) or not Self.ValidSlots[KeyID] then Exit;
    Value := Self.Values[KeyID];
    case Op of
      EBBOperator.Equal: Result := (Value = CompareWith);
      EBBOperator.NotEqual: Result := (Value <> CompareWith);
      EBBOperator.GreaterThan: Result := (Value > CompareWith);
      EBBOperator.LessThan: Result := (Value < CompareWith);
      EBBOperator.GreaterThanOrEqual: Result := (Value >= CompareWith);
      EBBOperator.LessThanOrEqual: Result := (Value <= CompareWith);
    end;
  except
    Result := False;
  finally
    Self.Lock.Leave();
  end;
end;

// Checks if a key is being watched for changes
function TBlackboard._IsKeyWatched(Key: String): Boolean;
var
  i: Integer;
begin
  for i := 0 to High(Self.WatchedKeys) do
    if Self.WatchedKeys[i] = Key then
      Exit(True);
  Result := False;
end;

(*
### TBlackboard.Watch
```pascal
procedure TBlackboard.Watch(Key: String);
```
Adds a key to the watch list for debugging.

Example:
```pascal
Blackboard.Watch('Health');
```
*)
procedure TBlackboard.Watch(Key: String);
begin
  if not Self._IsKeyWatched(Key) then
  begin
    SetLength(Self.WatchedKeys, Length(Self.WatchedKeys) + 1);
    Self.WatchedKeys[High(Self.WatchedKeys)] := Key;
  end;
end;

(*
### TBlackboard.Unwatch
```pascal
procedure TBlackboard.Unwatch(Key: String);
```
Removes a key from the watch list.

Example:
```pascal
Blackboard.Unwatch('Health');
```
*)
procedure TBlackboard.Unwatch(Key: String);
var
  i, j: Integer;
begin
  for i := 0 to High(Self.WatchedKeys) do
    if Self.WatchedKeys[i] = Key then
    begin
      for j := i to High(Self.WatchedKeys) - 1 do
        Self.WatchedKeys[j] := Self.WatchedKeys[j + 1];
      SetLength(Self.WatchedKeys, Length(Self.WatchedKeys) - 1);
      Break;
    end;
end;

(*
### TBlackboard.PrintEntries
```pascal
procedure TBlackboard.PrintEntries();
```
Prints all entries to console for debugging.

Example:
```pascal
Blackboard.PrintEntries();
```
*)
procedure TBlackboard.PrintEntries();
var
  Keys: TStringArray;
  i: Integer;
begin
  WriteLn('--- Blackboard Entries ---');
  Self.Lock.Enter();
  try
    Keys := Self.GetKeys();
    if Length(Keys) = 0 then
      WriteLn('(Empty)')
    else
      for i := 0 to High(Keys) do
        if Keys[i] <> '' then
          WriteLn(Format('%s = %s', [Keys[i], ToStr(Self.Get(Keys[i]))]));
  finally
    Self.Lock.Leave();
  end;
  WriteLn(''.PadLeft(25, '-'));
end;

(*
### TBlackboard.GetKeyID
```pascal
function TBlackboard.GetKeyID(Key: String): Integer;
```
Gets the internal ID for a key for optimized access.

Example:
```pascal
KeyID := Blackboard.GetKeyID('Health');
```
*)
function TBlackboard.GetKeyID(Key: String): Integer;
begin
  Self.Lock.Enter();
  try
    Result := Self._InternKey(Key);
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.GetByID
```pascal
function TBlackboard.GetByID(KeyID: Integer; Default: Variant = nil): Variant;
```
Gets a value using the internal key ID for optimized access.

Example:
```pascal
KeyID := Blackboard.GetKeyID('Health');
Health := Blackboard.GetByID(KeyID, 100); // Default to 100 if not found
```
*)
function TBlackboard.GetByID(KeyID: Integer; Default: Variant = nil): Variant;
begin
  Self.Lock.Enter();
  try
    if (KeyID < Length(Self.Values)) and Self.ValidSlots[KeyID] then
      Result := Self.Values[KeyID]
    else
      Result := Default;
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.PutByID
```pascal
procedure TBlackboard.PutByID(KeyID: Integer; Value: Variant);
```
Sets a value using the internal key ID for optimized access.

Example:
```pascal
KeyID := Blackboard.GetKeyID('Health');
Blackboard.PutByID(KeyID, 85);
```
*)
procedure TBlackboard.PutByID(KeyID: Integer; Value: Variant);
begin
  Self.Lock.Enter();
  try
    if KeyID >= Length(Self.Values) then
    begin
      SetLength(Self.Values, KeyID + 1);
      SetLength(Self.ValidSlots, KeyID + 1);
    end;
    
    Self.Values[KeyID] := Value;
    Self.ValidSlots[KeyID] := True;
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.PrintMetrics
```pascal
procedure TBlackboard.PrintMetrics();
```
Prints performance metrics for the blackboard.

Example:
```pascal
Blackboard.PrintMetrics();
```
*)
procedure TBlackboard.PrintMetrics();
var
  HitRate: Single;
begin
  Self.Lock.Enter();
  try
    if Self.StringIntern.TotalOps > 0 then
      HitRate := (Self.StringIntern.CacheHits / Self.StringIntern.TotalOps) * 100.0
    else
      HitRate := 0.0;
      
    WriteLn('--- Performance Metrics ---');
    WriteLn(Format('Cache Hit Rate: %.1f%%', [HitRate]));
    WriteLn(Format('Total Operations: %d', [Self.StringIntern.TotalOps]));
    WriteLn(Format('Cache Hits: %d', [Self.StringIntern.CacheHits]));
    WriteLn(Format('Cache Size: %d', [Length(Self.StringIntern.HashCache)]));
    WriteLn(Format('Unique Keys: %d', [Length(Self.StringIntern.IDToString)]));
    WriteLn(Format('Valid Entries: %d', [Self.Count()]));
    WriteLn(''.PadLeft(30, '-'));
  finally
    Self.Lock.Leave();
  end;
end;

// Adds change entries to activity stream for debugging
procedure TBlackboard._AddToActivityStream(Change: TBlackboardChange);
begin
  if Length(Self.ActivityStream) >= Self.MaxActivitySize then
  begin
    Move(Self.ActivityStream[1], Self.ActivityStream[0], 
         (Length(Self.ActivityStream) - 1) * SizeOf(TBlackboardChange));
    Self.ActivityStream[High(Self.ActivityStream)] := Change;
  end
  else
  begin
    SetLength(Self.ActivityStream, Length(Self.ActivityStream) + 1);
    Self.ActivityStream[High(Self.ActivityStream)] := Change;
  end;
end;

(*
### TBlackboard.GetActivitySince
```pascal
function TBlackboard.GetActivitySince(Timestamp: Double): array of TBlackboardChange;
```
Gets all activity changes since a specific timestamp.

Example:
```pascal
StartTime := PerformanceTime();
// ... do something ...
Changes := Blackboard.GetActivitySince(StartTime);
```
*)
function TBlackboard.GetActivitySince(Timestamp: Double): array of TBlackboardChange;
var
  i, Count: Integer;
begin
  SetLength(Result, 0);
  Count := 0;
  
  Self.Lock.Enter();
  try
    for i := 0 to High(Self.ActivityStream) do
      if Self.ActivityStream[i].Timestamp > Timestamp then
        Inc(Count);
    
    if Count > 0 then
    begin
      SetLength(Result, Count);
      Count := 0;
      for i := 0 to High(Self.ActivityStream) do
        if Self.ActivityStream[i].Timestamp > Timestamp then
        begin
          Result[Count] := Self.ActivityStream[i];
          Inc(Count);
        end;
    end;
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.GetRecentActivity
```pascal
function TBlackboard.GetRecentActivity(MaxCount: Integer = 50): array of TBlackboardChange;
```
Gets the most recent activity changes.

Example:
```pascal
RecentChanges := Blackboard.GetRecentActivity(20); // Get last 20 changes
```
*)
function TBlackboard.GetRecentActivity(MaxCount: Integer = 50): array of TBlackboardChange;
var
  i, StartIndex: Integer;
begin
  Self.Lock.Enter();
  try
    if Length(Self.ActivityStream) = 0 then
    begin
      SetLength(Result, 0);
      Exit;
    end;
    
    StartIndex := Max(0, Length(Self.ActivityStream) - MaxCount);
    SetLength(Result, Length(Self.ActivityStream) - StartIndex);
    
    for i := StartIndex to High(Self.ActivityStream) do
      Result[i - StartIndex] := Self.ActivityStream[i];
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.ClearActivity
```pascal
procedure TBlackboard.ClearActivity();
```
Clears the activity history.

Example:
```pascal
Blackboard.ClearActivity();
```
*)
procedure TBlackboard.ClearActivity();
begin
  Self.Lock.Enter();
  try
    SetLength(Self.ActivityStream, 0);
  finally
    Self.Lock.Leave();
  end;
end;

(*
### TBlackboard.PrintActivity
```pascal
procedure TBlackboard.PrintActivity(MaxCount: Integer = 20);
```
Prints recent activity for debugging.

Example:
```pascal
Blackboard.PrintActivity(10); // Print last 10 activities
```
*)
procedure TBlackboard.PrintActivity(MaxCount: Integer = 20);
var
  Activity: array of TBlackboardChange;
  i: Integer;
  TypeStr: String;
begin
  Activity := Self.GetRecentActivity(MaxCount);
  
  WriteLn('--- Activity Stream ---');
  if Length(Activity) = 0 then
    WriteLn('(No activity)')
  else
    for i := 0 to High(Activity) do
    begin
      case Activity[i].ChangeType of
        EBBChangeType.Create: TypeStr := 'CREATE';
        EBBChangeType.Update: TypeStr := 'UPDATE';
        EBBChangeType.Delete: TypeStr := 'DELETE';
        EBBChangeType.Read: TypeStr := 'READ';
      end;
      
      if Activity[i].ChangeType = EBBChangeType.Update then
        WriteLn(Format('[%.6f] %s %s: %s -> %s', [
          Activity[i].Timestamp, TypeStr, Activity[i].Key,
          ToStr(Activity[i].OldValue), ToStr(Activity[i].NewValue)]))
      else
        WriteLn(Format('[%.6f] %s %s: %s', [
          Activity[i].Timestamp, TypeStr, Activity[i].Key, ToStr(Activity[i].NewValue)]));
    end;
  WriteLn(''.PadLeft(25, '-'));
end;

// Validates blackboard key existence for error reporting
function TBlackboard._CheckKey(Key: String): String;
begin
  if not Self.HasKey(Key) then
    Result := Format('Key "%s" not found', [Key])
  else
    Result := '';
end;

(* TYPES *)

(*
## Types
Core types for behavior trees.
*)


const
  BT_MAX_RECURSION_DEPTH = 256;

type
  (*
  ### EBTStatus
  Execution status returned by nodes.
  
  ```pascal
  function MyAction(): EBTStatus;
  begin
    if TaskCompleted then
      Result := EBTStatus.Success
    else if TaskFailed then
      Result := EBTStatus.Failure
    else
      Result := EBTStatus.Running;
  end;
  ```
  *)
  EBTStatus = (Failure, Success, Running);

  (*
  ### EBTDebugLevel
  Debug output verbosity levels.
  
  ```pascal
  MyTree.SetDebugLevel(EBTDebugLevel.Verbose); // Detailed logging
  MyTree.SetDebugLevel(EBTDebugLevel.Silent);  // No logging
  ```
  *)
  EBTDebugLevel = (Silent, Errors, Normal, Verbose);

  (*
  ### EBTErrorType
  Types of errors that can occur.
  
  ```pascal
  if MyTree.HasErrors() then
  begin
    Error := MyTree.GetLastError();
    case Error.ErrorType of
      EBTErrorType.BlackboardError: WriteLn('Blackboard issue');
      EBTErrorType.InvalidNode: WriteLn('Node configuration issue');
    end;
  end;
  ```
  *)
  EBTErrorType = (None, InvalidNode, NullReference, MaxDepthExceeded, InvalidSubtree, BlackboardError);

  (*
  ### TBTAction
  Function type for action nodes.
  
  ```pascal
  function MyAction(): EBTStatus;
  begin
    // Your action logic here
    Result := EBTStatus.Success;
  end;
  
  ActionNode := MyTree.CreateAction('My Action', @MyAction);
  ```
  *)
  TBTAction = function(): EBTStatus;

  (*
  ### TBTActionMethod
  Method type for action nodes.
  
  ```pascal
  function TMyAI.MyAction(): EBTStatus;
  begin
    // Access object properties
    Result := EBTStatus.Success;
  end;
  
  ActionNode := MyTree.CreateAction('My Action', @Self.MyAction);
  ```
  *)
  TBTActionMethod = function(): EBTStatus of object;

  (*
  ### TBTCondition
  Function type for condition nodes.
  
  ```pascal
  function IsEnemyNearby(): Boolean;
  begin
    Result := CalculateEnemyDistance() < 100;
  end;
  
  ConditionNode := MyTree.CreateCondition('Enemy Nearby', @IsEnemyNearby);
  ```
  *)
  TBTCondition = function(): Boolean;

  (*
  ### TBTConditionMethod
  Method type for condition nodes.
  
  ```pascal
  function TMyAI.IsHealthLow(): Boolean;
  begin
    Result := Self.PlayerHealth < 25;
  end;
  
  ConditionNode := MyTree.CreateCondition('Health Low', @Self.IsHealthLow);
  ```
  *)
  TBTConditionMethod = function(): Boolean of object;

  // Node types enum
  EBTNodeType = (
    Action, Selector, Sequence, Inverter, Cooldown, Retry,
    ForceSuccess, ForceFailure, BlackboardCondition, Subtree,
    ParallelSequence, ParallelSelector, Conditional, RandomSelector,
    WeightedSelector, Timeout, Repeater, Condition, BlackboardSelector,
    Link, WaitForEvent, BroadcastEvent, EventCondition,
    ReactiveSelector, ReactiveSequence, DataGatherer,
    RepeatUntilSuccess, RepeatUntilFailure, Delay, Success, Failure, Running, Probability
  );

  // Forward declarations
  PBehaviorTree = ^TBehaviorTree;

  // Node handle
  TBTNodeHandle = record
    Index: Integer;
    NodeType: EBTNodeType;
  end;

  TBTNodeHandleArray = array of TBTNodeHandle;
  PBTNodeHandleArray = ^TBTNodeHandleArray;

  // Base node structure
  TBTNodeBase = record
    Name: String;
  end;

  // Node execution state
  TBTNodeState = record
    ExecutionCount: Integer;
    RunningChildIndex: Integer;
    RetryCount: Integer;
    RepeatCount: Integer;
  end;

  // Specific node types
  TBTActionNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Action: TBTAction;
    ActionMethod: TBTActionMethod;
  end;

  TBTCompositeNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Children: TBTNodeHandleArray;
    HasMemory: Boolean;
  end;

  TBTDecoratorNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Child: TBTNodeHandle;
  end;

  TBTRetryNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Child: TBTNodeHandle;
    MaxRetries: Integer;
  end;

  TBTTimerNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Child: TBTNodeHandle;
    TimerDuration: Integer;
    EndTime: Int64;
  end;

  TBTBlackboardConditionNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    BlackboardKey: String;
    CompareValue: Variant;
    BlackboardOperator: EBBOperator;
  end;

  TBTConditionalNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Child: TBTNodeHandle;
    Condition: TBTCondition;
    ConditionMethod: TBTConditionMethod;
  end;

  TBTConditionNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Condition: TBTCondition;
    ConditionMethod: TBTConditionMethod;
  end;

  TBTWeightedSelectorNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Children: TBTNodeHandleArray;
    Weights: TSingleArray;
  end;

  TBTBlackboardSelectorNode = record
      Base: TBTNodeBase;
      State: TBTNodeState;
      Children: TBTNodeHandleArray;
      BlackboardKey: String;
  end;

  TBTRepeaterNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Child: TBTNodeHandle;
    RepeatCount: Integer;
  end;

  TBTSubtreeNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    SubtreeIndex: Integer;
  end;

  TBTParallelTaskExecutor = record
    Tree: PBehaviorTree;
    NodeHandle: TBTNodeHandle;
    ChildIndex: Integer;
    Depth: Integer;
  end;

  TBTParallelNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Children: TBTNodeHandleArray;
    ParallelTimeoutMS: Integer;
    ParallelResults: array of EBTStatus;
    ParallelCompleted: array of Boolean;
    ParallelTasksSubmitted: Boolean;
    ParallelStartTime: Int64;
    Executors: array of TBTParallelTaskExecutor;
  end;

  TBTLinkNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    TargetNode: TBTNodeHandle;
  end;

  TBTWaitForEventNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    EventName: String;
    IsListening: Boolean;
    EventReceived: Boolean;
    EventData: Variant;
  end;

  TBTBroadcastEventNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    EventName: String;
    EventData: Variant;
  end;

  TBTEventConditionNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    EventName: String;
    ConsumeEvent: Boolean;
  end;

  TBTReactiveNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Children: TBTNodeHandleArray;
    LastConditionStates: array of EBTStatus;
    RunningChildIndex: Integer;
    ConditionCheckMask: array of Boolean;
    LastActivityTimestamp: Double;
    WatchedKey: String;
  end;

  TBTDataGathererNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    BlackboardKey: String;
    GatherFunction: TBTAction;
    GatherMethod: TBTActionMethod;
    UpdateInterval: Integer;
    LastUpdateTime: Double;
    ContinuousUpdate: Boolean;
  end;

  TBTRepeatUntilNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    Child: TBTNodeHandle;
    RepeatUntilSuccess: Boolean;
    MaxTries: Integer;
    CurrentTries: Integer;
  end;

  TBTDelayNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    DelayMS: Integer;
    StartTime: Int64;
  end;

  TBTStaticConditionNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    AlwaysTrue: Boolean;
    StaticResult: EBTStatus;
  end;

  TBTProbabilityNode = record
    Base: TBTNodeBase;
    State: TBTNodeState;
    SuccessChance: Single;
  end;

  (*
  ### TBTError
  Error information structure.
  
  ```pascal
  if MyTree.HasErrors() then
  begin
    Error := MyTree.GetLastError();
    WriteLn(Format('Error in node "%s": %s', [Error.NodeName, Error.Message]));
  end;
  ```
  *)
  TBTError = record
    ErrorType: EBTErrorType;
    Message: String;
    NodeName: String;
    Timestamp: Int64;
  end;

  // Debugging types (for verbose mode)
  TBTExecutionTrace = record
    NodePath: String;
    NodeName: String;
    Status: EBTStatus;
    ExecutionTime: Double;
    Depth: Integer;
    Timestamp: Int64;
  end;

  TBTNodeProfile = record
    NodeName: String;
    ExecutionCount: Integer;
    SuccessCount, FailureCount, RunningCount: Integer;
    TotalTimeMS, MinTimeMS, MaxTimeMS, AvgTimeMS: Double;
  end;

  // Main behavior tree record
  TBehaviorTree = record
    Name: String;
    Root: TBTNodeHandle;
    Blackboard: TBlackboard;
    Subtrees: array of PBehaviorTree;
    ThreadManager: TThreadManager;
    ParallelEnabled: Boolean;
    DefaultParallelTimeoutMS: Integer;
    Lock: TLock;
    OwnerOfLock: Boolean;
    OwnerOfBlackboard: Boolean;
    DebugLevel: EBTDebugLevel;
    CurrentExecutionDepth: Integer;
    
    // Node storage arrays
    ActionNodes: array of TBTActionNode;
    SelectorNodes: array of TBTCompositeNode;
    SequenceNodes: array of TBTCompositeNode;
    InverterNodes: array of TBTDecoratorNode;
    CooldownNodes: array of TBTTimerNode;
    RetryNodes: array of TBTRetryNode;
    ForceSuccessNodes: array of TBTDecoratorNode;
    ForceFailureNodes: array of TBTDecoratorNode;
    BlackboardConditionNodes: array of TBTBlackboardConditionNode;
    SubtreeNodes: array of TBTSubtreeNode;
    ParallelSequenceNodes: array of TBTParallelNode;
    ParallelSelectorNodes: array of TBTParallelNode;
    ConditionalNodes: array of TBTConditionalNode;
    RandomSelectorNodes: array of TBTCompositeNode;
    WeightedSelectorNodes: array of TBTWeightedSelectorNode;
    TimeoutNodes: array of TBTTimerNode;
    RepeaterNodes: array of TBTRepeaterNode;
    ConditionNodes: array of TBTConditionNode;
    BlackboardSelectorNodes: array of TBTBlackboardSelectorNode;
    LinkNodes: array of TBTLinkNode;
    WaitForEventNodes: array of TBTWaitForEventNode;
    BroadcastEventNodes: array of TBTBroadcastEventNode;
    EventConditionNodes: array of TBTEventConditionNode;
    ReactiveSelectorNodes: array of TBTReactiveNode;
    ReactiveSequenceNodes: array of TBTReactiveNode;
    DataGathererNodes: array of TBTDataGathererNode;
    RepeatUntilNodes: array of TBTRepeatUntilNode;
    DelayNodes: array of TBTDelayNode;
    StaticConditionNodes: array of TBTStaticConditionNode;
    ProbabilityNodes: array of TBTProbabilityNode;

    // Error handling and debugging
    LastError: TBTError;
    ErrorHistory: array of TBTError;
    ExecutionTrace: array of TBTExecutionTrace;
    MaxTraceSize: Integer;
    InterruptRequested: Boolean;
    InterruptReason: String;
  end; 

(* TREE *)

(*
## Tree Management
Core behavior tree management and execution.

Setup -> build tree structure -> Tick repeatedly -> Free when done.
*)



// Creates a new node of the specified type and returns a pointer to it
function TBehaviorTree._CreateNode(NodeType: EBTNodeType; out Index: Integer): Pointer;
var
  StaticNode: ^TBTStaticConditionNode;
begin
  Result := nil;
  case NodeType of
    EBTNodeType.Action: begin Index := Length(Self.ActionNodes); SetLength(Self.ActionNodes, Index + 1); Result := @Self.ActionNodes[Index]; end;
    EBTNodeType.Selector: begin Index := Length(Self.SelectorNodes); SetLength(Self.SelectorNodes, Index + 1); Result := @Self.SelectorNodes[Index]; end;
    EBTNodeType.Sequence: begin Index := Length(Self.SequenceNodes); SetLength(Self.SequenceNodes, Index + 1); Result := @Self.SequenceNodes[Index]; end;
    EBTNodeType.Inverter: begin Index := Length(Self.InverterNodes); SetLength(Self.InverterNodes, Index + 1); Result := @Self.InverterNodes[Index]; end;
    EBTNodeType.Cooldown: begin Index := Length(Self.CooldownNodes); SetLength(Self.CooldownNodes, Index + 1); Result := @Self.CooldownNodes[Index]; end;
    EBTNodeType.Retry: begin Index := Length(Self.RetryNodes); SetLength(Self.RetryNodes, Index + 1); Result := @Self.RetryNodes[Index]; end;
    EBTNodeType.ForceSuccess: begin Index := Length(Self.ForceSuccessNodes); SetLength(Self.ForceSuccessNodes, Index + 1); Result := @Self.ForceSuccessNodes[Index]; end;
    EBTNodeType.ForceFailure: begin Index := Length(Self.ForceFailureNodes); SetLength(Self.ForceFailureNodes, Index + 1); Result := @Self.ForceFailureNodes[Index]; end;
    EBTNodeType.BlackboardCondition: begin Index := Length(Self.BlackboardConditionNodes); SetLength(Self.BlackboardConditionNodes, Index + 1); Result := @Self.BlackboardConditionNodes[Index]; end;
    EBTNodeType.Subtree: begin Index := Length(Self.SubtreeNodes); SetLength(Self.SubtreeNodes, Index + 1); Result := @Self.SubtreeNodes[Index]; end;
    EBTNodeType.ParallelSequence: begin Index := Length(Self.ParallelSequenceNodes); SetLength(Self.ParallelSequenceNodes, Index + 1); Result := @Self.ParallelSequenceNodes[Index]; end;
    EBTNodeType.ParallelSelector: begin Index := Length(Self.ParallelSelectorNodes); SetLength(Self.ParallelSelectorNodes, Index + 1); Result := @Self.ParallelSelectorNodes[Index]; end;
    EBTNodeType.Conditional: begin Index := Length(Self.ConditionalNodes); SetLength(Self.ConditionalNodes, Index + 1); Result := @Self.ConditionalNodes[Index]; end;
    EBTNodeType.RandomSelector: begin Index := Length(Self.RandomSelectorNodes); SetLength(Self.RandomSelectorNodes, Index + 1); Result := @Self.RandomSelectorNodes[Index]; end;
    EBTNodeType.WeightedSelector: begin Index := Length(Self.WeightedSelectorNodes); SetLength(Self.WeightedSelectorNodes, Index + 1); Result := @Self.WeightedSelectorNodes[Index]; end;
    EBTNodeType.Timeout: begin Index := Length(Self.TimeoutNodes); SetLength(Self.TimeoutNodes, Index + 1); Result := @Self.TimeoutNodes[Index]; end;
    EBTNodeType.Repeater: begin Index := Length(Self.RepeaterNodes); SetLength(Self.RepeaterNodes, Index + 1); Result := @Self.RepeaterNodes[Index]; end;
    EBTNodeType.Condition: begin Index := Length(Self.ConditionNodes); SetLength(Self.ConditionNodes, Index + 1); Result := @Self.ConditionNodes[Index]; end;
    EBTNodeType.BlackboardSelector: begin Index := Length(Self.BlackboardSelectorNodes); SetLength(Self.BlackboardSelectorNodes, Index + 1); Result := @Self.BlackboardSelectorNodes[Index]; end;
    EBTNodeType.Link: begin Index := Length(Self.LinkNodes); SetLength(Self.LinkNodes, Index + 1); Result := @Self.LinkNodes[Index]; end;
    EBTNodeType.WaitForEvent: begin Index := Length(Self.WaitForEventNodes); SetLength(Self.WaitForEventNodes, Index + 1); Result := @Self.WaitForEventNodes[Index]; end;
    EBTNodeType.BroadcastEvent: begin Index := Length(Self.BroadcastEventNodes); SetLength(Self.BroadcastEventNodes, Index + 1); Result := @Self.BroadcastEventNodes[Index]; end;
    EBTNodeType.EventCondition: begin Index := Length(Self.EventConditionNodes); SetLength(Self.EventConditionNodes, Index + 1); Result := @Self.EventConditionNodes[Index]; end;
    EBTNodeType.ReactiveSelector: begin Index := Length(Self.ReactiveSelectorNodes); SetLength(Self.ReactiveSelectorNodes, Index + 1); Result := @Self.ReactiveSelectorNodes[Index]; end;
    EBTNodeType.ReactiveSequence: begin Index := Length(Self.ReactiveSequenceNodes); SetLength(Self.ReactiveSequenceNodes, Index + 1); Result := @Self.ReactiveSequenceNodes[Index]; end;
    EBTNodeType.DataGatherer: begin Index := Length(Self.DataGathererNodes); SetLength(Self.DataGathererNodes, Index + 1); Result := @Self.DataGathererNodes[Index]; end;
    EBTNodeType.RepeatUntilSuccess: begin Index := Length(Self.RepeatUntilNodes); SetLength(Self.RepeatUntilNodes, Index + 1); Result := @Self.RepeatUntilNodes[Index]; end;
    EBTNodeType.RepeatUntilFailure: begin Index := Length(Self.RepeatUntilNodes); SetLength(Self.RepeatUntilNodes, Index + 1); Result := @Self.RepeatUntilNodes[Index]; end;
    EBTNodeType.Delay: begin Index := Length(Self.DelayNodes); SetLength(Self.DelayNodes, Index + 1); Result := @Self.DelayNodes[Index]; end;
    EBTNodeType.Success: 
      begin 
        Index := Length(Self.StaticConditionNodes); 
        SetLength(Self.StaticConditionNodes, Index + 1); 
        StaticNode := @Self.StaticConditionNodes[Index];
        StaticNode^.StaticResult := EBTStatus.Success;
        Result := StaticNode;
      end;
    EBTNodeType.Failure: 
      begin 
        Index := Length(Self.StaticConditionNodes); 
        SetLength(Self.StaticConditionNodes, Index + 1); 
        StaticNode := @Self.StaticConditionNodes[Index];
        StaticNode^.StaticResult := EBTStatus.Failure;
        Result := StaticNode;
      end;
    EBTNodeType.Running: 
      begin 
        Index := Length(Self.StaticConditionNodes); 
        SetLength(Self.StaticConditionNodes, Index + 1); 
        StaticNode := @Self.StaticConditionNodes[Index];
        StaticNode^.StaticResult := EBTStatus.Running;
        Result := StaticNode;
      end;
    EBTNodeType.Probability: begin Index := Length(Self.ProbabilityNodes); SetLength(Self.ProbabilityNodes, Index + 1); Result := @Self.ProbabilityNodes[Index]; end;
  end;
end;

(*
### TBehaviorTree.AddSubtree
```pascal
function TBehaviorTree.AddSubtree(Subtree: PBehaviorTree): Integer;
```
Adds a subtree and shares blackboard resources.

Example:
```pascal
CombatIndex := MainTree.AddSubtree(CombatTree);
```
*)
function TBehaviorTree.AddSubtree(Subtree: PBehaviorTree): Integer;
begin
  Result := Length(Self.Subtrees);
  SetLength(Self.Subtrees, Result + 1);
  Self.Subtrees[Result] := Subtree;
  
  if Assigned(@Subtree^.Blackboard.Lock) and 
     (@Subtree^.Blackboard.Lock <> @Self.Blackboard.Lock) then
  begin
    try
      Subtree^.Blackboard.Free();
    except
    end;
  end;
  Subtree^.Blackboard := Self.Blackboard;
  Subtree^.OwnerOfBlackboard := False;
  
  if Subtree^.OwnerOfLock and Assigned(@Subtree^.Lock) and 
     (@Subtree^.Lock <> @Self.Lock) then
  begin
    try
      Subtree^.Lock.Free();
    except
    end;
    Subtree^.OwnerOfLock := False;
  end;
  Subtree^.Lock := Self.Lock;
end;

// Gets the base node structure from a node handle
function TBehaviorTree._GetNodeBase(Handle: TBTNodeHandle): Pointer;
begin
  Result := nil;
  if Handle.Index < 0 then Exit;
  case Handle.NodeType of
    EBTNodeType.Action: if Handle.Index < Length(Self.ActionNodes) then Result := @Self.ActionNodes[Handle.Index].Base;
    EBTNodeType.Selector: if Handle.Index < Length(Self.SelectorNodes) then Result := @Self.SelectorNodes[Handle.Index].Base;
    EBTNodeType.Sequence: if Handle.Index < Length(Self.SequenceNodes) then Result := @Self.SequenceNodes[Handle.Index].Base;
    EBTNodeType.Inverter: if Handle.Index < Length(Self.InverterNodes) then Result := @Self.InverterNodes[Handle.Index].Base;
    EBTNodeType.Cooldown: if Handle.Index < Length(Self.CooldownNodes) then Result := @Self.CooldownNodes[Handle.Index].Base;
    EBTNodeType.Retry: if Handle.Index < Length(Self.RetryNodes) then Result := @Self.RetryNodes[Handle.Index].Base;
    EBTNodeType.ForceSuccess: if Handle.Index < Length(Self.ForceSuccessNodes) then Result := @Self.ForceSuccessNodes[Handle.Index].Base;
    EBTNodeType.ForceFailure: if Handle.Index < Length(Self.ForceFailureNodes) then Result := @Self.ForceFailureNodes[Handle.Index].Base;
    EBTNodeType.BlackboardCondition: if Handle.Index < Length(Self.BlackboardConditionNodes) then Result := @Self.BlackboardConditionNodes[Handle.Index].Base;
    EBTNodeType.Subtree: if Handle.Index < Length(Self.SubtreeNodes) then Result := @Self.SubtreeNodes[Handle.Index].Base;
    EBTNodeType.ParallelSequence: if Handle.Index < Length(Self.ParallelSequenceNodes) then Result := @Self.ParallelSequenceNodes[Handle.Index].Base;
    EBTNodeType.ParallelSelector: if Handle.Index < Length(Self.ParallelSelectorNodes) then Result := @Self.ParallelSelectorNodes[Handle.Index].Base;
    EBTNodeType.Conditional: if Handle.Index < Length(Self.ConditionalNodes) then Result := @Self.ConditionalNodes[Handle.Index].Base;
    EBTNodeType.RandomSelector: if Handle.Index < Length(Self.RandomSelectorNodes) then Result := @Self.RandomSelectorNodes[Handle.Index].Base;
    EBTNodeType.WeightedSelector: if Handle.Index < Length(Self.WeightedSelectorNodes) then Result := @Self.WeightedSelectorNodes[Handle.Index].Base;
    EBTNodeType.Timeout: if Handle.Index < Length(Self.TimeoutNodes) then Result := @Self.TimeoutNodes[Handle.Index].Base;
    EBTNodeType.Repeater: if Handle.Index < Length(Self.RepeaterNodes) then Result := @Self.RepeaterNodes[Handle.Index].Base;
    EBTNodeType.Condition: if Handle.Index < Length(Self.ConditionNodes) then Result := @Self.ConditionNodes[Handle.Index].Base;
    EBTNodeType.BlackboardSelector: if Handle.Index < Length(Self.BlackboardSelectorNodes) then Result := @Self.BlackboardSelectorNodes[Handle.Index].Base;
    EBTNodeType.Link: if Handle.Index < Length(Self.LinkNodes) then Result := @Self.LinkNodes[Handle.Index].Base;
    EBTNodeType.WaitForEvent: if Handle.Index < Length(Self.WaitForEventNodes) then Result := @Self.WaitForEventNodes[Handle.Index].Base;
    EBTNodeType.BroadcastEvent: if Handle.Index < Length(Self.BroadcastEventNodes) then Result := @Self.BroadcastEventNodes[Handle.Index].Base;
    EBTNodeType.EventCondition: if Handle.Index < Length(Self.EventConditionNodes) then Result := @Self.EventConditionNodes[Handle.Index].Base;
    EBTNodeType.ReactiveSelector: if Handle.Index < Length(Self.ReactiveSelectorNodes) then Result := @Self.ReactiveSelectorNodes[Handle.Index].Base;
    EBTNodeType.ReactiveSequence: if Handle.Index < Length(Self.ReactiveSequenceNodes) then Result := @Self.ReactiveSequenceNodes[Handle.Index].Base;
    EBTNodeType.DataGatherer: if Handle.Index < Length(Self.DataGathererNodes) then Result := @Self.DataGathererNodes[Handle.Index].Base;
    EBTNodeType.RepeatUntilSuccess: if Handle.Index < Length(Self.RepeatUntilNodes) then Result := @Self.RepeatUntilNodes[Handle.Index].Base;
    EBTNodeType.RepeatUntilFailure: if Handle.Index < Length(Self.RepeatUntilNodes) then Result := @Self.RepeatUntilNodes[Handle.Index].Base;
    EBTNodeType.Delay: if Handle.Index < Length(Self.DelayNodes) then Result := @Self.DelayNodes[Handle.Index].Base;
    EBTNodeType.Success: if Handle.Index < Length(Self.StaticConditionNodes) then Result := @Self.StaticConditionNodes[Handle.Index].Base;
    EBTNodeType.Failure: if Handle.Index < Length(Self.StaticConditionNodes) then Result := @Self.StaticConditionNodes[Handle.Index].Base;
    EBTNodeType.Running: if Handle.Index < Length(Self.StaticConditionNodes) then Result := @Self.StaticConditionNodes[Handle.Index].Base;
    EBTNodeType.Probability: if Handle.Index < Length(Self.ProbabilityNodes) then Result := @Self.ProbabilityNodes[Handle.Index].Base;
  end;
end;

// Gets the execution state from a node handle
